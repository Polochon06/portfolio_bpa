---
import ProjectLayout from '../layouts/ProjectLayout.astro'

import vid1 from '../assets/works/Pen-4.mp4'
import vid2 from '../assets/works/Pen-5.mp4'
import vid3 from '../assets/works/Pen-6.mp4'
import heroBgImg from '../assets/bg-mt-conges.jpg'
import dashboardImg from '../assets/works/mt-conges-dashboard.png'
import loginImg from '../assets/works/mt-conges-login.png'
---

<ProjectLayout
  title="MT-Conges | Architecture Java MVC"
  description="Application desktop de gestion des conges. Java 17, Swing, MySQL, MVC, RBAC, BCrypt."
  heroLabel="Projet 01 · Atelier Pro BTS SIO · 2024"
  heroSub="Application desktop de gestion des conges avec workflow de validation multi-niveaux et systeme RBAC a 4 roles."
  techTags={["Java 17", "Java Swing", "MySQL 8", "MVC", "DAO", "BCrypt", "JDBC"]}
  heroBg={heroBgImg.src}
>
  <Fragment slot="hero-title">MT-<br/>CONGES</Fragment>

  <!-- ═══ 01 · STACK & CONTEXTE ════════════════════════════════════ -->
  <section class="p-section" data-reveal>
    <div class="p-section__header">
      <span class="p-section__num">01</span>
      <h2 class="p-section__title">Stack & Contexte</h2>
      <div class="p-section__line"></div>
    </div>

    <div class="p-grid">
      <div>
        <div class="p-body">
          <p>
            MT-Conges est une application desktop developpee dans le cadre d'un
            <strong>atelier de professionnalisation BTS SIO</strong> (equipe de 4).
            Elle simplifie la gestion des conges en entreprise avec
            <strong>trois profils utilisateurs distincts</strong> :
            Administrateur, Responsable et Employe.
          </p>
          <p>
            Chaque role dispose d'une interface Swing adaptative :
            l'employe soumet des demandes via calendrier, le responsable
            valide/refuse avec notification automatique, l'admin gere les
            comptes et permissions.
          </p>
        </div>

        <div class="p-stack" style="margin-top: 2rem;">
          {["Java SE-22", "Java Swing", "MySQL 8.0", "JDBC", "DAO Pattern", "BCrypt", "MVC", "Git", "SessionManager"].map(t => (
            <span class="p-tag">{t}</span>
          ))}
        </div>
      </div>

      <div class="p-card">
        <span class="p-card__label">Base de Donnees — adpv1 (7 tables)</span>
        <div>
          <div class="p-db-table">
            <div class="p-db-name">utilisateur</div>
            <div class="p-db-fields">IdUtilisateur, NomUtilisateur, Nom, Prenom<br/>Email, MotDePasse (BCrypt), NombreCongeRestant (30j)<br/>IdRole, IdProjet</div>
          </div>
          <div class="p-db-table">
            <div class="p-db-name">demandeconge</div>
            <div class="p-db-fields">IdConge, DureeConge, DateDebutConge<br/>EtatConge (En attente / Valide / Refuse)<br/>Motif, IdUtilisateur (FK CASCADE)</div>
          </div>
          <div class="p-db-table">
            <div class="p-db-name">role</div>
            <div class="p-db-fields">IdRole, NomRole, Permission (1–4)<br/>Super-Admin, Admin, Responsable, Employe</div>
          </div>
          <div class="p-db-table">
            <div class="p-db-name">notification</div>
            <div class="p-db-fields">IdNotification, Message, Statut<br/>DateCreation, DateLecture<br/>Liens: IdEvenement, IdConge, IdUtilisateur</div>
          </div>
          <div class="p-db-table">
            <div class="p-db-name">projet + projet_utilisateur</div>
            <div class="p-db-fields">Projets: CNP, Cyber · Association many-to-many<br/>Flag est_responsable (booleen)</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FEATURED IMAGE ══════════════════════════════════════════ -->
  <div class="p-featured" data-reveal>
    <img src={dashboardImg.src} alt="MT-Conges — Tableau de bord administrateur" loading="lazy" />
    <div class="p-featured__caption">Interface Administrateur — Tableau de Bord Principal</div>
  </div>

  <!-- ═══ 02 · ARCHITECTURE ════════════════════════════════════════ -->
  <section class="p-section" data-reveal>
    <div class="p-section__header">
      <span class="p-section__num">02</span>
      <h2 class="p-section__title">Architecture MVC</h2>
      <div class="p-section__line"></div>
    </div>

    <div class="p-grid">
      <div>
        <div class="p-body">
          <p>
            L'application repose sur une <strong>architecture MVC stricte</strong>
            en Java SE-22 avec interface graphique Swing. La couche DAO isole
            entierement l'acces base de donnees du reste de l'application.
          </p>
          <p>
            <strong>Workflow de validation :</strong>
          </p>
        </div>
        <ol class="p-steps" style="margin-top: 1.5rem;">
          <li>
            <strong>Soumission</strong>
            <span>L'employe selectionne les dates via le calendrier interactif et soumet sa demande</span>
          </li>
          <li>
            <strong>Notification</strong>
            <span>Une notification est automatiquement creee pour le responsable de projet</span>
          </li>
          <li>
            <strong>Validation</strong>
            <span>Le responsable valide ou refuse — une notification est envoyee a l'employe</span>
          </li>
          <li>
            <strong>Mise a jour solde</strong>
            <span>NombreCongeRestant mis a jour automatiquement apres acceptation</span>
          </li>
          <li>
            <strong>Detection conflits</strong>
            <span>Detection automatique des chevauchements entre demandes simultanees</span>
          </li>
        </ol>
      </div>

      <div>
        <div class="p-card" style="margin-bottom: 1.5rem;">
          <span class="p-card__label">Securite</span>
          <div class="p-mono-block">
            <div>✓ PreparedStatements JDBC (anti-injections SQL)</div>
            <div>✓ Hachage BCrypt des mots de passe</div>
            <div>✓ Verification RBAC au niveau DAO</div>
            <div>✓ SessionManager singleton pour les sessions</div>
            <div>✓ Contraintes FK DELETE CASCADE</div>
            <div>✓ UNIQUE sur association projet-utilisateur</div>
          </div>
        </div>

        <div class="p-showcase">
          <img src={loginImg.src} alt="Ecran de connexion MT-Conges" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ 03 · DEFIS & SOLUTIONS ═══════════════════════════════════ -->
  <section class="p-section" data-reveal>
    <div class="p-section__header">
      <span class="p-section__num">03</span>
      <h2 class="p-section__title">Defis & Solutions</h2>
      <div class="p-section__line"></div>
    </div>

    <div class="p-features">
      <div class="p-challenge">
        <span class="p-badge p-badge--problem">Securite</span>
        <h3>Injections SQL</h3>
        <p class="p-card__body">Les donnees RH (emails, mots de passe, soldes) sont sensibles. Une faille SQL compromettrait l'integralite de la base.</p>
        <hr class="p-challenge__sep" />
        <span class="p-badge p-badge--solution">Solution</span>
        <p class="p-card__body">Utilisation <strong style="color:var(--p-text)">exclusive</strong> de PreparedStatements JDBC pour toutes les requetes. Mots de passe chiffres avec BCrypt.</p>
      </div>

      <div class="p-challenge">
        <span class="p-badge p-badge--arch">Architecture</span>
        <h3>RBAC 4 Niveaux</h3>
        <p class="p-card__body">Gerer un systeme de permissions a 4 niveaux : Super-Admin, Admin, Responsable de projet et Employe standard.</p>
        <hr class="p-challenge__sep" />
        <span class="p-badge p-badge--solution">Solution</span>
        <p class="p-card__body">Table <strong style="color:var(--p-text)">role</strong> avec colonne Permission (1–4). SessionManager singleton. Interfaces Swing adaptatives selon le role.</p>
      </div>

      <div class="p-challenge">
        <span class="p-badge p-badge--problem">Integrite</span>
        <h3>Coherence Multi-Tables</h3>
        <p class="p-card__body">Maintenir l'integrite entre 7 tables. Empecher les chevauchements de conges et les soldes negatifs.</p>
        <hr class="p-challenge__sep" />
        <span class="p-badge p-badge--solution">Solution</span>
        <p class="p-card__body">Contraintes SQL : DELETE CASCADE, UNIQUE sur projet-utilisateur, indices optimises. Validation metier cote Java avant insertion.</p>
      </div>

      <div class="p-challenge">
        <span class="p-badge p-badge--ux">UX</span>
        <h3>Systeme de Notifications</h3>
        <p class="p-card__body">Badge rouge avec compteur de non-lues, generation automatique lors des demandes/decisions, filtrage lues/non lues.</p>
        <hr class="p-challenge__sep" />
        <span class="p-badge p-badge--solution">Solution</span>
        <p class="p-card__body">Table <strong style="color:var(--p-text)">notification</strong> avec statut, timestamps, liens contextuels. Badge UI dynamique. Onglets de filtrage.</p>
      </div>
    </div>
  </section>

  <!-- ═══ 04 · SHOWCASE VIDEO ══════════════════════════════════════ -->
  <section class="p-section" data-reveal>
    <div class="p-section__header">
      <span class="p-section__num">04</span>
      <h2 class="p-section__title">Showcase Video</h2>
      <div class="p-section__line"></div>
    </div>

    <p class="p-body" style="max-width:600px; margin-bottom:3rem;">
      <span style="opacity:0.6">Extraits de demonstration de l'application en fonctionnement.</span>
    </p>

    <div class="p-videos">
      <div class="p-video">
        <video src={vid1} controls loop muted playsinline></video>
      </div>
      <div class="p-video">
        <video src={vid2} controls loop muted playsinline></video>
      </div>
      <div class="p-video">
        <video src={vid3} controls loop muted playsinline></video>
      </div>
    </div>
  </section>

  <!-- ═══ STATS ═════════════════════════════════════════════════════ -->
  <div class="p-stats" data-reveal>
    <div class="p-stat">
      <div class="p-stat__num">7</div>
      <div class="p-stat__label">Tables SQL</div>
    </div>
    <div class="p-stat">
      <div class="p-stat__num">4</div>
      <div class="p-stat__label">Niveaux Roles</div>
    </div>
    <div class="p-stat">
      <div class="p-stat__num">100%</div>
      <div class="p-stat__label">PreparedStmts</div>
    </div>
    <div class="p-stat">
      <div class="p-stat__num">3</div>
      <div class="p-stat__label">Mois Projet</div>
    </div>
  </div>

</ProjectLayout>
