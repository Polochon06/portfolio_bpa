  <script>
    import { gsap } from 'gsap'

    // ── ELEMENTS ────────────────────────────────────────────────────────
    const scenes   = Array.from(document.querySelectorAll<HTMLElement>('.scene'))
    const navDots  = Array.from(document.querySelectorAll<HTMLElement>('.nav-dot'))
    const videos   = Array.from(document.querySelectorAll<HTMLVideoElement>('.bg-vid'))
    const barStatus = document.getElementById('bar-status')!
    const progressBar = document.getElementById('progress-bar')!

    // ── SCENE DATA ──────────────────────────────────────────────────────
    type SceneInfo = {
      el: HTMLElement
      vidIndex: number
      lines: HTMLElement[]   // .ti elements — slide from bottom
      fades: HTMLElement[]   // .fade-in elements
      status: string
    }

    const sceneData: SceneInfo[] = scenes.map(el => ({
      el,
      vidIndex: parseInt(el.dataset.vid ?? '1') - 1,
      lines: Array.from(el.querySelectorAll<HTMLElement>('.ti')),
      fades: Array.from(el.querySelectorAll<HTMLElement>('.fade-in')),
      status: el.dataset.status ?? '',
    }))

    // ── VIDEO SETUP ─────────────────────────────────────────────────────
    let currentVid = 0
    let kenTween: gsap.core.Tween | null = null
    const vidDurations = new Array<number>(videos.length).fill(5.5)

    // GSAP controls all transforms (no CSS transform on .bg-vid)
    gsap.set(videos, { scale: 1.0 })

    videos.forEach((vid, i) => {
      if (vid.readyState >= 1) vidDurations[i] = vid.duration || 5.5
      vid.addEventListener('loadedmetadata', () => { vidDurations[i] = vid.duration })
    })

    function switchVideo(index: number) {
      if (index === currentVid) return
      const next = videos[index]
      const prev = videos[currentVid]

      // Lazy load
      if (next.preload === 'none') { next.preload = 'auto'; next.load() }
      const after = videos[index + 1]
      if (after?.preload === 'none') { after.preload = 'metadata'; after.load() }

      // 3D entrance — zoom from depth + defocus
      gsap.killTweensOf(next)
      gsap.set(next, { scale: 1.18, filter: 'blur(14px)' })
      gsap.to(next, {
        scale: 1.06, filter: 'blur(0px)',
        duration: 1.6, ease: 'expo.out',
      })

      // Crossfade
      next.classList.add('active')
      setTimeout(() => {
        prev.classList.remove('active')
        gsap.to(prev, { scale: 1.0, filter: 'blur(0px)', duration: 0.3 })
        setTimeout(() => prev.pause(), 400)
      }, 300)

      // Ken Burns — slow zoom out while video plays
      kenTween?.kill()
      next.currentTime = 0
      next.play().catch(() => {})
      const dur = vidDurations[index] || 5.5
      kenTween = gsap.to(next, { scale: 1.0, duration: dur, ease: 'none' })

      currentVid = index
    }

    // ── LETTERBOX ───────────────────────────────────────────────────────
    const lboxT = document.querySelector<HTMLElement>('.lbox-t')!
    const lboxB = document.querySelector<HTMLElement>('.lbox-b')!
    gsap.to([lboxT, lboxB], {
      translateY: 0, duration: 1, ease: 'power3.out', delay: 0.2,
    })

    // ── SCENE TRANSITION ────────────────────────────────────────────────
    let active = 0
    let busy = false

    function hideScene(info: SceneInfo) {
      gsap.killTweensOf([...info.lines, ...info.fades])
      gsap.to(info.lines, { yPercent: -110, duration: 0.35, stagger: 0.04, ease: 'power2.in' })
      gsap.to(info.fades, { opacity: 0, y: -12, duration: 0.3, stagger: 0.03, ease: 'power2.in' })
    }

    function showScene(info: SceneInfo) {
      // Lines: slide from bottom
      gsap.set(info.lines, { yPercent: 110 })
      gsap.to(info.lines, {
        yPercent: 0,
        duration: 0.85, stagger: 0.09, ease: 'power3.out',
      })
      // Fades: opacity + slight Y
      gsap.set(info.fades, { opacity: 0, y: 18 })
      gsap.to(info.fades, {
        opacity: 1, y: 0,
        duration: 0.7, stagger: 0.08, ease: 'power2.out',
        delay: 0.3,
      })
    }

    function goTo(index: number, instant = false) {
      if (busy || index === active || index < 0 || index >= scenes.length) return
      busy = true

      const from = sceneData[active]
      const to   = sceneData[index]

      // Hide current scene text
      hideScene(from)

      // Switch video
      switchVideo(to.vidIndex)

      // Update nav + status
      navDots.forEach((d, j) => d.classList.toggle('active', j === index))
      barStatus.textContent = to.status
      progressBar.style.width = `${(index / (scenes.length - 1)) * 100}%`

      const delay = instant ? 0 : 0.18

      // Scene visibility swap
      gsap.delayedCall(delay, () => {
        from.el.classList.remove('active')
        to.el.classList.add('active')

        // Wait for video to end — THEN show text (the "pause" behavior)
        const vid = videos[to.vidIndex]
        vid.addEventListener('ended', () => {
          if (active !== index) return
          vid.pause()
          kenTween?.pause()
          showScene(to)
        }, { once: true })

        // Allow next navigation after transition
        gsap.delayedCall(0.6, () => { busy = false })
      })

      active = index
    }

    // ── S1: Intro animation on page load ────────────────────────────────
    ;(() => {
      const s1 = sceneData[0]
      gsap.set(s1.lines, { yPercent: 110 })
      // Eyebrow + sub
      const eyebrow = document.querySelector<HTMLElement>('.hero-eyebrow')!
      const sub     = document.querySelector<HTMLElement>('.hero-sub')!
      const hint    = document.querySelector<HTMLElement>('.scroll-hint')!
      gsap.set([eyebrow, sub, hint], { opacity: 0 })

      const tl = gsap.timeline({ delay: 0.4 })
      tl.to(eyebrow, { opacity: 1, duration: 0.8, ease: 'power2.out' })
      tl.to(s1.lines, { yPercent: 0, duration: 1.0, stagger: 0.12, ease: 'power3.out' }, '-=0.4')
      tl.to(sub,  { opacity: 1, duration: 0.7, ease: 'power2.out' }, '-=0.5')
      tl.to(hint, { opacity: 1, duration: 0.6, ease: 'power2.out' }, '-=0.3')

      // Start video
      videos[0].play().catch(() => {})
      const dur = vidDurations[0] || 5.5
      kenTween = gsap.to(videos[0], { scale: 1.0, duration: dur, ease: 'none' })
      gsap.set(videos[0], { scale: 1.06 })

      // S1 video ends → animate hint more prominently (no text to reveal)
      videos[0].addEventListener('ended', () => {
        if (active !== 0) return
        videos[0].pause()
        kenTween?.pause()
        // Pulse hint to invite interaction
        gsap.to(hint, { opacity: 0.9, y: -4, yoyo: true, repeat: -1, duration: 1.2, ease: 'sine.inOut' })
      })
    })()

    // ── WHEEL ───────────────────────────────────────────────────────────
    let wheelAcc = 0
    let wheelTimer: ReturnType<typeof setTimeout> | null = null

    window.addEventListener('wheel', (e) => {
      wheelAcc += e.deltaY
      if (wheelTimer) clearTimeout(wheelTimer)
      wheelTimer = setTimeout(() => {
        if (Math.abs(wheelAcc) > 20) goTo(active + (wheelAcc > 0 ? 1 : -1))
        wheelAcc = 0
      }, 60)
    }, { passive: true })

    // ── TOUCH ───────────────────────────────────────────────────────────
    let touchY0 = 0
    document.addEventListener('touchstart', (e) => { touchY0 = e.touches[0].clientY }, { passive: true })
    document.addEventListener('touchend', (e) => {
      const dy = touchY0 - e.changedTouches[0].clientY
      if (Math.abs(dy) > 50) goTo(active + (dy > 0 ? 1 : -1))
    }, { passive: true })

    // ── KEYBOARD ────────────────────────────────────────────────────────
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown' || e.key === 'PageDown') goTo(active + 1)
      if (e.key === 'ArrowUp'   || e.key === 'PageUp')   goTo(active - 1)
    })

    // ── NAV DOTS ────────────────────────────────────────────────────────
    navDots.forEach((dot) => {
      dot.addEventListener('click', () => {
        goTo(parseInt(dot.dataset.scene ?? '0'))
      })
    })

    // ── LOGO → S1 ───────────────────────────────────────────────────────
    document.getElementById('logo-btn')?.addEventListener('click', () => goTo(0))
  </script>

