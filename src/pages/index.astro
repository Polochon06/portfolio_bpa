---
import SiteHead from '../components/SiteHead.astro'
import SiteFoot from '../components/SiteFoot.astro'
import SiteScrollbar from '../components/SiteScrollbar.astro'
import SiteTutorial from '../components/SiteTutorial.astro'
import SHero from '../components/SHero.astro'
import SAbout from '../components/SAbout.astro'
import SWork from '../components/SWork.astro'
import SMyWay from '../components/SMyWay.astro'
import SCTA from '../components/SCTA.astro'
import ASeparator from '../components/ASeparator.astro'
import '../styles/global.scss'
---

<html lang="en" class="is-scroll-blocked theme-contrasted">
  <head>
    <meta charset="utf-8" />

    <title>Paul Blanc Portfolio</title>

    <meta
      name="description"
      content="Portfolio of Paul Blanc, Creative Developer."
    />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <meta name="robots" content="noindex, nofollow" />
    <link rel="canonical" href="https://portfolio-paul-blanc.netlify.app/" />

    <link
      rel="icon"
      type="image/png"
      href="/icons/favicon-48x48.png"
      sizes="48x48"
    />
    <link rel="icon" type="image/svg+xml" href="/icons/favicon.svg" />
    <link rel="shortcut icon" href="/icons/favicon.ico" />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/icons/apple-touch-icon.png"
    />
    <meta name="apple-mobile-web-app-title" content="Paul Blanc Portfolio" />

    <meta name="theme-color" content="#160000" />
    <meta name="msapplication-navbutton-color" content="#160000" />
    <meta name="apple-mobile-web-app-status-bar-style" content="#160000" />

    <meta property="og:locale" content="en_GB" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Paul Blanc Portfolio" />
    <meta
      property="og:description"
      content="Portfolio of Paul Blanc, Creative Developer."
    />
    <meta
      property="og:url"
      content="https://portfolio-paul-blanc.netlify.app/"
    />
    <meta property="og:site_name" content="Paul Blanc Portfolio" />
    <meta
      property="og:image"
      content="https://portfolio-paul-blanc.netlify.app/images/og-image.png"
    />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="675" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:image"
      content="https://portfolio-paul-blanc.netlify.app/images/og-image.png"
    />

    <link
      rel="preload"
      href="/fonts/PPEditorialNew-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/PPEditorialNew-Ultralight.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/PPFraktionMono-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/PPFraktionMono-Bold.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/Bigger-Display.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
  </head>

  <body>
    <div class="site-wrapper js-site-wrapper" style="opacity: 0;">
      <SiteHead />

      <SHero />

      <SAbout />

      <ASeparator style="secondary" />

      <SWork />

      <ASeparator style="secondary" />

      <SMyWay />

      <SCTA />

      <SiteFoot />
    </div><!-- .site-wrapper -->

    <div
      class="site-intro js-intro"
      style="opacity: 1; position: fixed; top: 0; left: 0; z-index: 50; width: 100%; height: 100%;"
    >
      <canvas class="js-portal-canvas" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"></canvas>
    </div><!-- .site-intro -->

    <div class="site-mount js-mount"></div>
    <div class="site-contrast-mask js-contrast-mask"></div>

    <SiteScrollbar />
    <SiteTutorial />
  </body>

  <script>
    import Emitter from '../utils/Emitter'
    import Ticker from '../utils/Ticker'

    import Lenis from 'lenis'

    import { gsap } from 'gsap'
    import { ScrollTrigger } from 'gsap/ScrollTrigger'
    gsap.registerPlugin(ScrollTrigger)

    declare global {
      interface Window {
        safeWidth: number
        safeHeight: number
        maxScrollTop: number
        scrollProgress: number
        lenis: any
      }
    }

    class Site {
      timeouts: any = {
        resizeThrottle: null,
      }

      windowWidth: number
      windowHeight: number
      clientWidth: number
      clientHeight: number

      isScrolling: boolean = false

      lenis: any

      /**
       * Constructor
       */
      constructor() {
        // OS class
        let os = 'unknown'
        if (navigator.userAgent.indexOf('Win') !== -1) {
          os = 'windows'
        } else if (navigator.userAgent.indexOf('Android') !== -1) {
          os = 'android'
        } else if (navigator.userAgent.indexOf('Mac') !== -1) {
          os = 'mac'
        } else if (navigator.userAgent.indexOf('Linux') !== -1) {
          os = 'linux'
        }
        document.documentElement.classList.add(`is-${os}`)

        // Browser class
        let browser = 'unknown'
        if (navigator.userAgent.indexOf('Firefox') !== -1) {
          browser = 'firefox'
        } else if (navigator.userAgent.indexOf('Chrome') !== -1) {
          browser = 'chrome'
        } else if (navigator.userAgent.indexOf('Safari') !== -1) {
          browser = 'safari'
        }
        document.documentElement.classList.add(`is-${browser}`)

        this.bindEvents()
      }

      /**
       * Initialization
       */
      init() {
        this.initLenis()

        Ticker.init()

        this.onResize()
        Ticker.nextTick(this.intro, this)
      }

      /**
       * Bind events
       */
      bindEvents() {
        window.addEventListener('resize', this.resizeThrottle.bind(this))
        window.addEventListener('scroll', this.onScroll.bind(this), {
          passive: true,
        })
        window.addEventListener('mousemove', this.onMouseMove.bind(this), {
          passive: true,
        })

        Emitter.on('updateViewport', this.onResize, this, true)

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              entry.target.dispatchEvent(
                new CustomEvent('intersect', {
                  detail: { isIntersecting: entry.isIntersecting },
                }),
              )

              if (entry.isIntersecting) {
                entry.target.classList.add('is-in-view')
                entry.target.classList.remove(
                  'is-out-of-view',
                  'is-out-of-view-top',
                  'is-out-of-view-bottom',
                )
              } else {
                entry.target.classList.remove('is-in-view')
                entry.target.classList.add('is-out-of-view')

                entry.target.classList.toggle(
                  'is-out-of-view-top',
                  entry.boundingClientRect.top < 0,
                )
                entry.target.classList.toggle(
                  'is-out-of-view-bottom',
                  entry.boundingClientRect.top > 0,
                )
              }
            })
          },
          {
            threshold: 0,
          },
        )

        document.querySelectorAll('[data-intersect]').forEach((el) => {
          observer.observe(el)
        })

        // Site loaded event
        if (document.readyState === 'complete') {
          this.siteLoaded()
        } else {
          window.addEventListener('load', this.siteLoaded, { once: true })
        }

        this.onScroll()
      }

      /**
       * Init lenis
       */
      initLenis() {
        const lenis = new Lenis()

        lenis.on('scroll', ScrollTrigger.update)

        gsap.ticker.add((time) => {
          lenis.raf(time * 1000)
        })

        gsap.ticker.lagSmoothing(0)

        window.lenis = lenis
        this.lenis = lenis
      }

      /**
       * Set loaded class
       */
      siteLoaded() {
        document.documentElement.classList.add('is-loaded')

        Emitter.emit('siteLoaded')
      }

      /**
       * Resize throttle
       */
      resizeThrottle() {
        clearTimeout(this.timeouts.resizeThrottle)

        this.timeouts.resizeThrottle = setTimeout(() => {
          Ticker.nextTick(this.onResize, this)
        }, 200)
      }

      /**
       * Resize handler
       */
      onResize() {
        const newWidth = window.innerWidth
        let widthChanged = false
        if (this.windowWidth !== newWidth) {
          if (this.windowWidth !== undefined) {
            widthChanged = true
          }

          this.windowWidth = newWidth
          this.clientWidth = document.body.clientWidth
        }

        const newHeight = window.innerHeight
        let heightChanged = false
        if (this.windowHeight !== newHeight) {
          if (this.windowHeight !== undefined) {
            heightChanged = true
          }

          this.windowHeight = newHeight
          this.clientHeight = document.body.clientHeight
        }

        window.safeWidth = newWidth
        window.safeHeight = newHeight

        window.maxScrollTop = document.body.scrollHeight - window.safeHeight

        this.setScrollProgress()

        Emitter.emit('resize', widthChanged, heightChanged)
      }

      /**
       * Scroll handler
       */
      onScroll() {
        this.setScrollProgress()

        Ticker.nextTick(() => {
          Emitter.emit('scroll', window.scrollY)
        })
      }

      /**
       * Set scroll progress
       */
      setScrollProgress() {
        window.scrollProgress = window.scrollY / window.maxScrollTop
      }

      /**
       * Mouse move handler
       */
      onMouseMove(e) {
        Emitter.emit('mousemove', e.clientX, e.clientY)
      }

      /**
       * Intro — Doctor Strange portal v4 (lightning, runes, sound, reveal)
       */
      intro() {
        const wrapper = document.querySelector('.js-site-wrapper') as HTMLElement
        const intro  = document.querySelector('.js-intro') as HTMLElement
        const mount  = document.querySelector('.js-mount') as HTMLElement
        const canvas = intro.querySelector('.js-portal-canvas') as HTMLCanvasElement
        const ctx    = canvas.getContext('2d') as CanvasRenderingContext2D

        canvas.width  = window.innerWidth
        canvas.height = window.innerHeight

        const cx = canvas.width  / 2
        const cy = canvas.height / 2
        const R       = Math.min(canvas.width, canvas.height) * 0.30
        const maxDim  = Math.max(canvas.width, canvas.height)

        // ── State ──────────────────────────────────────────────────────
        let phase        = 'forming'
        let t            = 0
        let currentR     = 0
        let openProgress = 0
        let flashAlpha   = 0
        let trailAlpha   = 0.05
        let ringFade     = 1

        const sparks:  any[] = []
        const bolts:   any[] = []
        const embers:  any[] = []
        const ripples: any[] = []
        let nextBolt   = 0.6
        let nextRipple = 0.4

        const nodeRings = [
          { ratio: 0.38, count: 4, spd:  0.45, sz: 4.5, rgb: '80,180,255'  },
          { ratio: 0.62, count: 6, spd: -0.28, sz: 3.2, rgb: '60,160,255'  },
          { ratio: 0.86, count: 9, spd:  0.18, sz: 2.4, rgb: '100,210,255' },
        ]

        const inflows: any[] = []
        let nextInflow = 0.0
        const stars = Array.from({length: 65}, () => ({
          frac:    0.06 + Math.random() * 0.80,
          angle:   Math.random() * Math.PI * 2,
          dA:      (Math.random() < 0.5 ? 1 : -1) * (0.0015 + Math.random() * 0.006),
          sz:      0.18 + Math.random() * 0.52,
          twinkle: Math.random() * Math.PI * 2,
          twSpeed: 1.8 + Math.random() * 3.5,
        }))

        // ── Web Audio (procedural, fails silently if blocked) ──────────
        ;(function initAudio() {
          try {
            const AC  = (window as any).AudioContext || (window as any).webkitAudioContext
            const ac  = new AC()
            const now = ac.currentTime

            // Low hum
            const osc  = ac.createOscillator()
            osc.type   = 'sawtooth'
            osc.frequency.setValueAtTime(52, now)
            osc.frequency.linearRampToValueAtTime(78, now + 3)
            const og   = ac.createGain()
            og.gain.setValueAtTime(0, now)
            og.gain.linearRampToValueAtTime(0.06, now + 0.9)
            og.gain.setValueAtTime(0.06, now + 1.8)
            og.gain.linearRampToValueAtTime(0, now + 3.0)
            osc.connect(og); og.connect(ac.destination); osc.start(); osc.stop(now + 3.5)

            // Electrical crackle (filtered noise)
            const buf = ac.createBuffer(1, ac.sampleRate * 4, ac.sampleRate)
            const d   = buf.getChannelData(0)
            for (let i = 0; i < d.length; i++) d[i] = Math.random() * 2 - 1
            const ns  = ac.createBufferSource(); ns.buffer = buf
            const bpf = ac.createBiquadFilter(); bpf.type = 'bandpass'
            bpf.frequency.value = 2400; bpf.Q.value = 1.5
            const ng  = ac.createGain()
            ng.gain.setValueAtTime(0, now)
            ng.gain.linearRampToValueAtTime(0.04, now + 0.8)
            ng.gain.linearRampToValueAtTime(0.07, now + 1.8)
            ng.gain.linearRampToValueAtTime(0, now + 3.0)
            ns.connect(bpf); bpf.connect(ng); ng.connect(ac.destination); ns.start()

            // Opening whoosh at t=3.4s
            setTimeout(() => {
              try {
                const w  = ac.createOscillator(); w.type = 'sine'
                w.frequency.setValueAtTime(110, ac.currentTime)
                w.frequency.exponentialRampToValueAtTime(2200, ac.currentTime + 0.6)
                const wg = ac.createGain()
                wg.gain.setValueAtTime(0.2, ac.currentTime)
                wg.gain.exponentialRampToValueAtTime(0.001, ac.currentTime + 1.0)
                w.connect(wg); wg.connect(ac.destination)
                w.start(); w.stop(ac.currentTime + 1.2)
              } catch(e) {}
            }, 2000)
          } catch(e) { /* autoplay blocked — silent */ }
        })()

        // ── Spawn spark ────────────────────────────────────────────────
        function spawnSpark() {
          const cw   = Math.random() < 0.75
          const lane = Math.random()
          // 3 couches orbitales : inner / main / outer
          const rMul = lane < 0.18 ? 0.87 : lane < 0.80 ? 1.0 : 1.13
          sparks.push({
            angle:    Math.random() * Math.PI * 2,
            r:        currentR * rMul * (0.96 + Math.random() * 0.08),
            orbitSpd: cw
              ? (0.020 + Math.random() * 0.052) * (rMul < 1 ? 1.10 : rMul > 1 ? 0.91 : 1)
              : -(0.014 + Math.random() * 0.040),
            sz:       lane < 0.18 ? (0.20 + Math.random() * 0.85)
                    : lane < 0.80 ? (0.28 + Math.random() * 1.55)
                    : (0.18 + Math.random() * 0.75),
            hue:      192 + Math.random() * 55,
            life:     1.0,
            decay:    0.22 + Math.random() * 0.52,
          })
        }

        // ── Spawn lightning bolt avec branche secondaire ───────────────
        function spawnBolt() {
          const a1   = Math.random() * Math.PI * 2
          const span = Math.PI * (0.20 + Math.random() * 0.80)
          const a2   = a1 + span * (Math.random() > 0.5 ? 1 : -1)
          const x1   = cx + Math.cos(a1) * currentR
          const y1   = cy + Math.sin(a1) * currentR
          const x2   = cx + Math.cos(a2) * currentR
          const y2   = cy + Math.sin(a2) * currentR
          const segs = 8 + Math.floor(Math.random() * 8)
          const dx   = x2 - x1, dy = y2 - y1
          const pts: {x:number,y:number}[] = [{x:x1,y:y1}]
          for (let i = 1; i < segs; i++) {
            const f = i / segs
            pts.push({
              x: x1 + dx * f + (Math.random() - 0.5) * 40,
              y: y1 + dy * f + (Math.random() - 0.5) * 40,
            })
          }
          pts.push({x:x2, y:y2})
          const hue = 200 + Math.random() * 40
          bolts.push({ pts, life: 1.0, decay: 4.5 + Math.random() * 5, hue })
          // Branche depuis un point médian aléatoire
          if (Math.random() > 0.38) {
            const bi  = 2 + Math.floor(Math.random() * (segs - 3))
            const bp  = pts[bi]
            const bPts: {x:number,y:number}[] = [{ x: bp.x, y: bp.y }]
            const bLen = 3 + Math.floor(Math.random() * 3)
            const bDx  = (Math.random() - 0.5) * 58
            const bDy  = (Math.random() - 0.5) * 58
            for (let i = 1; i <= bLen; i++) {
              bPts.push({
                x: bp.x + bDx * (i / bLen) + (Math.random() - 0.5) * 18,
                y: bp.y + bDy * (i / bLen) + (Math.random() - 0.5) * 18,
              })
            }
            bolts.push({ pts: bPts, life: 0.8, decay: 7 + Math.random() * 7, hue, isBranch: true })
          }
        }

        // ── Spawn ember — particule qui s'échappe de l'anneau ──────────
        function spawnEmber() {
          const angle   = Math.random() * Math.PI * 2
          const outward = Math.random() > 0.25
          const speed   = 48 + Math.random() * 92
          embers.push({
            x:     cx + Math.cos(angle) * currentR,
            y:     cy + Math.sin(angle) * currentR,
            vx:    Math.cos(angle) * (outward ? 1 : -0.45) * speed
                 + Math.cos(angle + Math.PI / 2) * (Math.random() - 0.5) * 30,
            vy:    Math.sin(angle) * (outward ? 1 : -0.45) * speed
                 + Math.sin(angle + Math.PI / 2) * (Math.random() - 0.5) * 30,
            sz:    0.38 + Math.random() * 1.1,
            hue:   192 + Math.random() * 55,
            life:  1.0,
            decay: 1.0 + Math.random() * 1.4,
          })
        }

        // ── Spawn inflow — particule aspirée vers le portail ──────────
        function spawnInflow() {
          const side = Math.floor(Math.random() * 4)
          let x: number, y: number
          if      (side === 0) { x = Math.random() * canvas.width; y = -15 }
          else if (side === 1) { x = canvas.width + 15;  y = Math.random() * canvas.height }
          else if (side === 2) { x = Math.random() * canvas.width; y = canvas.height + 15 }
          else                 { x = -15; y = Math.random() * canvas.height }
          const dx = cx - x, dy = cy - y
          const dist = Math.sqrt(dx * dx + dy * dy)
          const spd  = 55 + Math.random() * 85
          inflows.push({
            x, y,
            vx: (dx / dist) * spd,
            vy: (dy / dist) * spd,
            hue: 195 + Math.random() * 50,
            sz:  0.35 + Math.random() * 0.90,
            life: 1.0,
          })
        }

        // ── Update ──────────────────────────────────────────────────────
        function update(dt: number) {
          t        += dt
          currentR  = phase === 'forming' ? Math.min(currentR + dt * R / 1.0, R) : R

          if (phase === 'opening') {
            openProgress = Math.min(openProgress + dt * 0.85, 1)
            flashAlpha   = Math.max(flashAlpha - dt * 2.8, 0)
            ringFade   = Math.max(0, 1 - openProgress * 3)
            trailAlpha = 0.32 * Math.max(0, 1 - openProgress * 1.1)
            if (openProgress >= 1) phase = 'done'
          }

          if (phase !== 'done') {
            const rate = phase === 'full' ? 80 : phase === 'opening' ? 22 : 12
            for (let i = 0; i < rate * dt; i++) spawnSpark()
          }

          // Lightning: only when ring is mature
          if ((phase === 'full' || (phase === 'opening' && openProgress < 0.28)) && currentR > R * 0.6) {
            nextBolt -= dt
            if (nextBolt <= 0) {
              spawnBolt()
              if (Math.random() > 0.55) spawnBolt()
              nextBolt = 0.06 + Math.random() * 0.22
            }
          }

          for (let i = sparks.length - 1; i >= 0; i--) {
            const p = sparks[i]
            p.angle += p.orbitSpd
            p.r      = currentR + Math.sin(p.angle * 6 + t * 1.8) * currentR * 0.028
            p.life  -= p.decay * dt
            if (p.life <= 0) sparks.splice(i, 1)
          }

          for (let i = bolts.length - 1; i >= 0; i--) {
            bolts[i].life -= bolts[i].decay * dt
            if (bolts[i].life <= 0) bolts.splice(i, 1)
          }

          // Embers & ripples — phase full uniquement
          if (phase === 'full' && currentR > R * 0.5) {
            if (Math.random() < 14 * dt) spawnEmber()
            nextRipple -= dt
            if (nextRipple <= 0) {
              ripples.push({ r: currentR, life: 1.0 })
              nextRipple = 0.40 + Math.random() * 0.55
            }
          }

          for (let i = embers.length - 1; i >= 0; i--) {
            const e  = embers[i]
            const dr = Math.pow(0.88, dt * 60)
            e.x += e.vx * dt; e.vx *= dr
            e.y += e.vy * dt; e.vy *= dr
            e.life -= e.decay * dt
            if (e.life <= 0) embers.splice(i, 1)
          }

          for (let i = ripples.length - 1; i >= 0; i--) {
            ripples[i].r    += 55 * dt
            ripples[i].life -= 0.85 * dt
            if (ripples[i].life <= 0) ripples.splice(i, 1)
          }

          // Inflow particles — aspirées vers le centre
          if ((phase === 'forming' || phase === 'full') && currentR > R * 0.25) {
            nextInflow -= dt
            if (nextInflow <= 0) {
              spawnInflow()
              nextInflow = 0.05 + Math.random() * 0.11
            }
          }
          for (let i = inflows.length - 1; i >= 0; i--) {
            const p  = inflows[i]
            const dx = cx - p.x, dy = cy - p.y
            const dist = Math.sqrt(dx * dx + dy * dy)
            const accel = 180 / Math.max(dist, 32)
            p.vx += (dx / dist) * accel * dt * 60
            p.vy += (dy / dist) * accel * dt * 60
            p.x  += p.vx * dt
            p.y  += p.vy * dt
            p.life -= dt * 0.32
            if (p.life <= 0 || dist < currentR * 0.52) inflows.splice(i, 1)
          }

          // Stars slow orbit
          for (const s of stars) s.angle += s.dA * dt * 60
        }

        // ── Draw ────────────────────────────────────────────────────────
        function draw() {
          ctx.fillStyle = `rgba(0,4,18,${trailAlpha})`
          ctx.fillRect(0, 0, canvas.width, canvas.height)

          const rVis = currentR > 8

          // Flash — white burst on opening
          if (flashAlpha > 0) {
            const fg = ctx.createRadialGradient(cx, cy, 0, cx, cy, R * 2.0)
            fg.addColorStop(0,    `rgba(255,255,255,${flashAlpha * 0.88})`)
            fg.addColorStop(0.25, `rgba(120,200,255,${flashAlpha * 0.55})`)
            fg.addColorStop(0.65, `rgba(20,80,255,${flashAlpha * 0.22})`)
            fg.addColorStop(1,    'rgba(0,20,100,0)')
            ctx.beginPath(); ctx.arc(cx, cy, R * 2.0, 0, Math.PI * 2)
            ctx.fillStyle = fg; ctx.fill()
          }

          // Macro aura — large ambient halo far beyond ring
          if (rVis) {
            const auraR = currentR * 2.6
            const auraA = (0.18 + flashAlpha * 0.12) * ringFade * Math.min(t * 0.55, 1)
            if (auraA > 0.005) {
              const ag = ctx.createRadialGradient(cx, cy, currentR * 0.85, cx, cy, auraR)
              ag.addColorStop(0,   `rgba(0,80,255,${auraA * 0.55})`)
              ag.addColorStop(0.4, `rgba(0,50,200,${auraA * 0.28})`)
              ag.addColorStop(1,   'rgba(0,10,60,0)')
              ctx.beginPath(); ctx.arc(cx, cy, auraR, 0, Math.PI * 2)
              ctx.fillStyle = ag; ctx.fill()
            }
          }

          // Outer glow halo
          if (rVis) {
            const gw = 82 + flashAlpha * 30
            const ga = (0.44 + flashAlpha * 0.56) * ringFade
            const rg = ctx.createRadialGradient(cx, cy, Math.max(0, currentR - gw * 0.55), cx, cy, currentR + gw)
            rg.addColorStop(0,    'rgba(0,40,180,0)')
            rg.addColorStop(0.26, `rgba(0,100,255,${ga * 0.68})`)
            rg.addColorStop(0.50, `rgba(80,180,255,${ga})`)
            rg.addColorStop(0.76, `rgba(140,210,255,${ga * 0.52})`)
            rg.addColorStop(1,    'rgba(0,40,180,0)')
            ctx.beginPath()
            ctx.arc(cx, cy, currentR + gw, 0, Math.PI * 2)
            ctx.fillStyle = rg
            ctx.fill()
          }

          // Inflow particles — disparaissent dans le portail grâce à destination-out
          if (rVis && inflows.length > 0) {
            ctx.save()
            ctx.globalCompositeOperation = 'screen'
            ctx.shadowBlur = 6
            for (const p of inflows) {
              const a = p.life * 0.50
              if (a < 0.02) continue
              ctx.shadowColor = `hsla(${p.hue},90%,72%,${a * 0.8})`
              ctx.beginPath(); ctx.arc(p.x, p.y, p.sz * 0.55, 0, Math.PI * 2)
              ctx.fillStyle = `hsla(${p.hue},90%,82%,${a})`
              ctx.fill()
            }
            ctx.restore()
          }

          // ── Portal window (destination-out) ───────────────────────────
          let windowR: number
          if (phase === 'forming')   windowR = currentR * 0.84
          else                       windowR = R * 0.84
          if (windowR > 2) {
            ctx.save()
            ctx.globalCompositeOperation = 'destination-out'
            const hg = ctx.createRadialGradient(cx, cy, 0, cx, cy, windowR)
            hg.addColorStop(0.80, 'rgba(0,0,0,1)')
            hg.addColorStop(0.95, 'rgba(0,0,0,0.88)')
            hg.addColorStop(1,    'rgba(0,0,0,0)')
            ctx.beginPath()
            ctx.arc(cx, cy, windowR, 0, Math.PI * 2)
            ctx.fillStyle = hg
            ctx.fill()
            ctx.restore()
          }

          // ── Ripples — ondes concentriques pulsant depuis l'anneau ────────
          for (const rp of ripples) {
            const a = rp.life * 0.30 * ringFade
            if (a < 0.01) continue
            ctx.beginPath()
            ctx.arc(cx, cy, rp.r, 0, Math.PI * 2)
            ctx.strokeStyle = `rgba(80,170,255,${a})`
            ctx.lineWidth   = rp.life * 1.8
            ctx.stroke()
          }

          // ── Dimensional vortex — inside the portal ───────────────────────
          if (windowR > 8) {
            const vA = phase === 'forming'
              ? Math.pow(Math.min(currentR / R, 1), 1.4)
              : phase === 'full'
                ? 1.0
                : Math.max(0, 1 - openProgress * 6)
            if (vA > 0.005) {
              const clipR = Math.min(windowR * 0.89, R * 0.89)
              ctx.save()
              ctx.globalAlpha = vA
              ctx.beginPath(); ctx.arc(cx, cy, clipR, 0, Math.PI * 2); ctx.clip()

              // Base: deep space
              const bg = ctx.createRadialGradient(cx, cy, 0, cx, cy, clipR)
              bg.addColorStop(0,   'rgba(0,8,40,1)')
              bg.addColorStop(0.55,'rgba(0,4,18,1)')
              bg.addColorStop(1,   'rgba(0,0,0,0.92)')
              ctx.fillStyle = bg; ctx.fillRect(cx - clipR, cy - clipR, clipR * 2, clipR * 2)

              // Blue mist — drifting luminous cloud
              const mistAng = t * 0.08
              const mA = (0.22 + Math.sin(t * 0.75) * 0.06) * Math.min(t * 0.55, 1)
              const mG = ctx.createRadialGradient(
                cx + Math.cos(mistAng) * clipR * 0.22, cy + Math.sin(mistAng) * clipR * 0.22,
                0, cx, cy, clipR * 0.82)
              mG.addColorStop(0,   `rgba(20,100,255,${mA})`)
              mG.addColorStop(0.45,`rgba(0,50,180,${mA * 0.30})`)
              mG.addColorStop(1,   'rgba(0,0,0,0)')
              ctx.beginPath(); ctx.arc(cx, cy, clipR * 0.82, 0, Math.PI * 2)
              ctx.fillStyle = mG; ctx.fill()

              // Concentric inner rings — pulsing depth
              ctx.shadowBlur = 0
              for (let i = 1; i <= 5; i++) {
                const ir    = clipR * (i / 6.2)
                const shift = i * 0.85 + t * (i % 2 === 0 ? 1.6 : -1.2)
                const a     = (0.14 + Math.sin(shift) * 0.06) * Math.min(t * 1.1, 1)
                ctx.beginPath(); ctx.arc(cx, cy, ir, 0, Math.PI * 2)
                ctx.strokeStyle = `rgba(60,140,255,${a})`
                ctx.lineWidth   = 0.8 + Math.sin(shift * 0.65) * 0.4
                ctx.stroke()
              }

              // Central singularity
              const singPulse = 1 + Math.sin(t * 4.8) * 0.12
              const singR = clipR * (0.18 + Math.sin(t * 5.2) * 0.022) * singPulse
              const singG = ctx.createRadialGradient(cx, cy, 0, cx, cy, singR)
              singG.addColorStop(0,    `rgba(255,255,255,${0.92 + flashAlpha * 0.08})`)
              singG.addColorStop(0.18, `rgba(180,230,255,0.72)`)
              singG.addColorStop(0.50, `rgba(30,120,255,0.30)`)
              singG.addColorStop(0.80, `rgba(0,30,100,0.10)`)
              singG.addColorStop(1,    'rgba(0,0,0,0)')
              ctx.beginPath(); ctx.arc(cx, cy, singR, 0, Math.PI * 2)
              ctx.fillStyle = singG; ctx.fill()

              // Stars — points de lumière dans l'espace dimensionnel
              ctx.shadowBlur = 0
              for (const s of stars) {
                const sr  = clipR * s.frac
                const sx  = cx + Math.cos(s.angle) * sr
                const sy  = cy + Math.sin(s.angle) * sr
                const twi = 0.5 + Math.sin(t * s.twSpeed + s.twinkle) * 0.5
                const a   = twi * 0.65
                if (a < 0.05) continue
                ctx.beginPath(); ctx.arc(sx, sy, s.sz, 0, Math.PI * 2)
                ctx.fillStyle = `rgba(190,225,255,${a})`
                ctx.fill()
              }

              ctx.restore()
            }
          }

          // ── Chromatic aberration — red/blue ring split at portal edge ─────
          if (rVis && ringFade > 0.05 && phase !== 'forming') {
            const ca = (0.28 + flashAlpha * 0.40) * ringFade
            ctx.save()
            ctx.globalCompositeOperation = 'screen'
            ctx.beginPath(); ctx.arc(cx, cy, currentR - 2.5, 0, Math.PI * 2)
            ctx.strokeStyle = `rgba(255,30,80,${ca * 0.72})`; ctx.lineWidth = 1.4; ctx.stroke()
            ctx.beginPath(); ctx.arc(cx, cy, currentR + 2.5, 0, Math.PI * 2)
            ctx.strokeStyle = `rgba(60,140,255,${ca * 0.72})`; ctx.lineWidth = 1.4; ctx.stroke()
            ctx.restore()
          }

          // ── Below: drawn over site content ────────────────────────────

          // Orbital nodes — glowing points on concentric orbits with short trails
          if (rVis) {
            const baseA = Math.min(t * 1.1, 1) * ringFade
            if (baseA > 0.01) {
              ctx.save()
              // Faint guide circles
              ctx.strokeStyle = `rgba(60,140,255,${baseA * 0.10})`
              ctx.lineWidth = 0.5
              for (const nr of nodeRings) {
                ctx.beginPath(); ctx.arc(cx, cy, currentR * nr.ratio, 0, Math.PI * 2); ctx.stroke()
              }
              // Glowing orbital nodes + trails
              ctx.globalCompositeOperation = 'screen'
              for (const nr of nodeRings) {
                const r   = currentR * nr.ratio
                const rot = t * nr.spd
                for (let i = 0; i < nr.count; i++) {
                  const ang   = (i / nr.count) * Math.PI * 2 + rot
                  const pulse = 0.55 + Math.sin(t * 2.2 + i * 1.57) * 0.45
                  const a     = baseA * pulse
                  const nx    = cx + Math.cos(ang) * r
                  const ny    = cy + Math.sin(ang) * r
                  // Short trailing arc
                  ctx.beginPath()
                  if (nr.spd > 0) ctx.arc(cx, cy, r, ang - 0.20, ang, false)
                  else            ctx.arc(cx, cy, r, ang, ang + 0.20, true)
                  ctx.strokeStyle = `rgba(${nr.rgb},${a * 0.32})`
                  ctx.lineWidth   = nr.sz * 0.65
                  ctx.stroke()
                  // Node radial glow
                  const ng = ctx.createRadialGradient(nx, ny, 0, nx, ny, nr.sz * 2.8)
                  ng.addColorStop(0,    `rgba(230,248,255,${a})`)
                  ng.addColorStop(0.35, `rgba(${nr.rgb},${a * 0.45})`)
                  ng.addColorStop(1,    'rgba(0,0,0,0)')
                  ctx.beginPath(); ctx.arc(nx, ny, nr.sz * 2.8, 0, Math.PI * 2)
                  ctx.fillStyle = ng; ctx.fill()
                }
              }
              ctx.restore()
            }
          }

          // Energy band — 2-pass electric ring
          if (rVis) {
            const sa = (phase === 'forming' ? currentR / R : 1) * (0.72 + flashAlpha * 0.28) * ringFade
            if (sa > 0.01) {
              ctx.save()
              ctx.shadowColor = `rgba(0,140,255,${sa * 0.58})`
              ctx.shadowBlur  = 32
              ctx.beginPath(); ctx.arc(cx, cy, currentR, 0, Math.PI * 2)
              ctx.strokeStyle = `rgba(0,80,220,${sa * 0.32})`
              ctx.lineWidth   = 11
              ctx.stroke()
              ctx.shadowBlur  = 10
              ctx.shadowColor = `rgba(180,230,255,${sa})`
              ctx.beginPath(); ctx.arc(cx, cy, currentR - 1.2, 0, Math.PI * 2)
              ctx.strokeStyle = `rgba(220,245,255,${sa * 0.88})`
              ctx.lineWidth   = 1.4
              ctx.stroke()
              ctx.restore()
            }
          }

          // Lightning bolts + branches
          for (const b of bolts) {
            const sc = b.isBranch ? 0.52 : 1.0
            ctx.save()
            ctx.shadowColor = `hsla(${b.hue},100%,72%,${b.life * sc})`
            ctx.shadowBlur  = b.isBranch ? 8 : 18
            ctx.strokeStyle = `hsla(${b.hue},100%,82%,${b.life * 0.90 * sc})`
            ctx.lineWidth   = (b.isBranch ? 0.55 : 1.1) + b.life * (b.isBranch ? 0.38 : 0.88)
            ctx.beginPath(); ctx.moveTo(b.pts[0].x, b.pts[0].y)
            for (let i = 1; i < b.pts.length; i++) ctx.lineTo(b.pts[i].x, b.pts[i].y)
            ctx.stroke()
            ctx.shadowBlur  = b.isBranch ? 3 : 6
            ctx.strokeStyle = `rgba(230,245,255,${b.life * (b.isBranch ? 0.38 : 0.60)})`
            ctx.lineWidth   = b.isBranch ? 0.35 : 0.55
            ctx.beginPath(); ctx.moveTo(b.pts[0].x, b.pts[0].y)
            for (let i = 1; i < b.pts.length; i++) ctx.lineTo(b.pts[i].x, b.pts[i].y)
            ctx.stroke()
            ctx.restore()
          }

          // Sparks — lighter blend for electric additive glow
          ctx.save()
          ctx.globalCompositeOperation = 'lighter'
          for (const p of sparks) {
            const alpha = p.life * ringFade
            if (alpha < 0.02) continue
            const trailLen = 0.22 + p.sz * 0.068
            ctx.beginPath()
            if (p.orbitSpd > 0) {
              ctx.arc(cx, cy, p.r, p.angle - trailLen, p.angle, false)
            } else {
              ctx.arc(cx, cy, p.r, p.angle, p.angle + trailLen, true)
            }
            ctx.strokeStyle = `hsla(${p.hue},100%,60%,${alpha * 0.28})`
            ctx.lineWidth   = p.sz * 0.55
            ctx.stroke()
            const x = cx + Math.cos(p.angle) * p.r
            const y = cy + Math.sin(p.angle) * p.r
            ctx.shadowColor = `hsla(${p.hue},100%,80%,${alpha * 0.85})`
            ctx.shadowBlur  = 8
            ctx.beginPath()
            ctx.fillStyle = `hsla(${p.hue},100%,90%,${alpha * 0.80})`
            ctx.arc(x, y, p.sz * 0.58, 0, Math.PI * 2)
            ctx.fill()
          }
          ctx.shadowBlur = 0
          ctx.restore()

          // Hotspots — 3 bright nodes orbiting the ring
          if (rVis && ringFade > 0.04) {
            ctx.save()
            ctx.globalCompositeOperation = 'lighter'
            for (let i = 0; i < 3; i++) {
              const ha     = t * 0.28 + (i / 3) * Math.PI * 2
              const hpulse = 0.24 + Math.sin(t * 1.9 + i * 2.4) * 0.11
              ctx.shadowColor = `rgba(180,230,255,${ringFade * hpulse})`
              ctx.shadowBlur  = 24
              ctx.beginPath()
              ctx.fillStyle = `rgba(240,252,255,${ringFade * hpulse * 0.88})`
              ctx.arc(cx + Math.cos(ha) * currentR, cy + Math.sin(ha) * currentR, 3.5, 0, Math.PI * 2)
              ctx.fill()
            }
            ctx.restore()
          }

          // Embers — particules qui s'échappent de l'anneau
          ctx.shadowColor = 'rgba(100,190,255,0.75)'
          ctx.shadowBlur  = 8
          for (const e of embers) {
            const a = e.life * ringFade
            if (a < 0.02) continue
            ctx.beginPath()
            ctx.fillStyle = `hsla(${e.hue},100%,82%,${a * 0.88})`
            ctx.arc(e.x, e.y, e.sz * 0.52, 0, Math.PI * 2)
            ctx.fill()
          }
          ctx.shadowBlur = 0; ctx.shadowColor = 'transparent'

          // Energy core — rotating rays + halo + white dot
          const coreR     = phase === 'forming' ? Math.max(currentR * 0.09, 5) : R * 0.24
          const pulse     = 1 + Math.sin(t * 6.5) * 0.10 + flashAlpha * 0.28
          const coreAlpha = Math.max(0, 1 - openProgress * 2)
          if (coreAlpha > 0.01) {
            ctx.save()
            ctx.shadowColor = `rgba(0,160,255,${coreAlpha * 0.52})`
            ctx.shadowBlur  = 20
            const beamRot = t * 0.35
            for (let i = 0; i < 8; i++) {
              const ba   = (i / 8) * Math.PI * 2 + beamRot
              const bLen = coreR * pulse * (2.0 + Math.sin(t * 2.8 + i) * 0.32)
              ctx.beginPath()
              ctx.moveTo(cx, cy)
              ctx.lineTo(cx + Math.cos(ba) * bLen, cy + Math.sin(ba) * bLen)
              ctx.strokeStyle = `rgba(0,140,255,${coreAlpha * 0.15})`
              ctx.lineWidth   = 1.7
              ctx.stroke()
            }
            ctx.restore()
            const cg = ctx.createRadialGradient(cx, cy, 0, cx, cy, coreR * pulse * 1.55)
            cg.addColorStop(0,    `rgba(255,255,255,${(0.82 + flashAlpha * 0.18) * coreAlpha})`)
            cg.addColorStop(0.14, `rgba(120,210,255,${(0.78 + flashAlpha * 0.14) * coreAlpha})`)
            cg.addColorStop(0.38, `rgba(0,120,255,${(0.50 + flashAlpha * 0.16) * coreAlpha})`)
            cg.addColorStop(0.72, `rgba(0,40,170,${0.15 * coreAlpha})`)
            cg.addColorStop(1,    'rgba(0,0,0,0)')
            ctx.beginPath(); ctx.arc(cx, cy, coreR * pulse * 1.55, 0, Math.PI * 2)
            ctx.fillStyle = cg; ctx.fill()
            ctx.save()
            ctx.shadowColor = `rgba(255,255,255,${coreAlpha * 0.92})`
            ctx.shadowBlur  = 24
            ctx.beginPath()
            ctx.fillStyle = `rgba(255,255,255,${coreAlpha * 0.94})`
            ctx.arc(cx, cy, Math.max(1.5, coreR * 0.11 * pulse), 0, Math.PI * 2)
            ctx.fill()
            ctx.restore()
          }

          // Self-bloom — canvas se re-dessine sur lui-même flou en mode screen
          if (rVis && phase !== 'done') {
            ctx.save()
            ctx.globalCompositeOperation = 'screen'
            ctx.globalAlpha = 0.38
            ctx.filter = 'blur(14px)'
            ctx.drawImage(canvas, 0, 0)
            ctx.filter = 'none'
            ctx.restore()
          }

          // Opening bloom — white radial explosion fills the entire screen
          if (phase === 'opening') {
            const fillA = Math.min(openProgress * 2.2, 1.0)
            // Full-canvas white wash (covers dark edges)
            ctx.fillStyle = `rgba(255,255,255,${fillA})`
            ctx.fillRect(0, 0, canvas.width, canvas.height)
            // Extra radial brightness at center while ramping up
            if (fillA < 1) {
              const ease   = 1 - Math.pow(1 - openProgress, 2.5)
              const bloomR = R * 0.5 + ease * maxDim * 1.6
              const cg     = ctx.createRadialGradient(cx, cy, 0, cx, cy, bloomR)
              cg.addColorStop(0,    `rgba(255,255,255,${fillA})`)
              cg.addColorStop(0.40, `rgba(180,228,255,${fillA * 0.55})`)
              cg.addColorStop(1,    'rgba(0,0,0,0)')
              ctx.fillStyle = cg
              ctx.fillRect(0, 0, canvas.width, canvas.height)
            }
          }
        }

        // Pre-fill before first rAF to avoid flash
        ctx.fillStyle = '#00040e'
        ctx.fillRect(0, 0, canvas.width, canvas.height)

        let lastTime = 0
        let rafId: any = 0

        const tick = (time: number) => {
          const dt = Math.min((time - lastTime) / 1000, 0.05)
          lastTime = time
          update(dt)
          draw()
          if (phase !== 'done') rafId = requestAnimationFrame(tick)
        }

        rafId = requestAnimationFrame((ts: number) => {
          lastTime = ts
          rafId = requestAnimationFrame(tick)
        })

        const tl = gsap.timeline()
        tl.set(wrapper, { opacity: '' })

        tl.call(() => { phase = 'full' }, null, 1.0)

        tl.call(() => {
          phase      = 'opening'
          flashAlpha = 1
          trailAlpha = 0.22
          mount.style.opacity = '1'
        }, null, 2.2)

        tl.call(() => {
          document.dispatchEvent(new CustomEvent('intro'))
        }, null, 2.7)

        tl.call(() => {
          cancelAnimationFrame(rafId)
          gsap.to(intro, { opacity: 0, duration: 0.38, ease: 'power1.in', onComplete: () => {
            intro.remove()
            document.documentElement.classList.remove('is-scroll-blocked')
            Ticker.nextTick(() => { Emitter.emit('updateViewport') })
          }})
        }, null, 2.9)
      }
    }

    const site = new Site()

    // Site init on DOM ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', site.init, { once: true })
    } else {
      site.init()
    }
  </script>

  <style lang="scss">
    body {
      position: relative;

      padding: 1rem;
      min-height: 100vh;

      @include mq(phone) {
        padding: 0.5rem;
      }
    }

    .site-contrast-mask {
      position: fixed;
      top: 0;
      left: 0;
      z-index: 20;

      width: 100%;
      height: 100%;

      background: map.get($theme-colors, 'default', 'primary');
      border-color: map.get($theme-colors, 'default', 'secondary');
      border-style: solid;
      border-width: 0 1rem 0 0;
      mix-blend-mode: darken;
      transform: translate3d(-100%, 0, 0);

      pointer-events: none;
      will-change: transform;

      @include mq(phone) {
        border-right-width: 0.5rem;
      }
    }

    .site-intro {
      position: fixed;
      top: 0;
      left: 0;
      z-index: 50;

      width: 100%;
      height: 100%;

      background: transparent;
    }

    .site-wrapper {
      position: relative;
      z-index: 2;

      background: color(primary);
      clip-path: inset(0 -1rem);

      @include mq(phone) {
        clip-path: inset(0 -0.5rem);
      }
    }

    .site-mount {
      position: absolute;
      top: 0;
      left: 0;
      z-index: 1;

      width: 100%;
      height: 100%;

      border: 1rem solid color(secondary);

      opacity: 0;
      will-change: border-width;

      pointer-events: none;
    }
  </style>
</html>
