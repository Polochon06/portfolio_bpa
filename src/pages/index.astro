---
import SiteHead from '../components/SiteHead.astro'
import SiteFoot from '../components/SiteFoot.astro'
import SiteScrollbar from '../components/SiteScrollbar.astro'
import SiteTutorial from '../components/SiteTutorial.astro'
import SHero from '../components/SHero.astro'
import SAbout from '../components/SAbout.astro'
import SWork from '../components/SWork.astro'
import SMyWay from '../components/SMyWay.astro'
import SCTA from '../components/SCTA.astro'
import ASeparator from '../components/ASeparator.astro'
import SiteCursor from '../components/SiteCursor.astro'
import '../styles/global.scss'
---

<html lang="en" class="is-scroll-blocked theme-contrasted">
  <head>
    <meta charset="utf-8" />

    <title>Paul Blanc Portfolio</title>

    <meta
      name="description"
      content="Portfolio of Paul Blanc, Creative Developer."
    />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <meta name="robots" content="noindex, nofollow" />
    <link rel="canonical" href="https://portfolio-paul-blanc.netlify.app/" />

    <link
      rel="icon"
      type="image/png"
      href="/icons/favicon-48x48.png"
      sizes="48x48"
    />
    <link rel="icon" type="image/svg+xml" href="/icons/favicon.svg" />
    <link rel="shortcut icon" href="/icons/favicon.ico" />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/icons/apple-touch-icon.png"
    />
    <meta name="apple-mobile-web-app-title" content="Paul Blanc Portfolio" />

    <meta name="theme-color" content="#160000" />
    <meta name="msapplication-navbutton-color" content="#160000" />
    <meta name="apple-mobile-web-app-status-bar-style" content="#160000" />

    <meta property="og:locale" content="en_GB" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Paul Blanc Portfolio" />
    <meta
      property="og:description"
      content="Portfolio of Paul Blanc, Creative Developer."
    />
    <meta
      property="og:url"
      content="https://portfolio-paul-blanc.netlify.app/"
    />
    <meta property="og:site_name" content="Paul Blanc Portfolio" />
    <meta
      property="og:image"
      content="https://portfolio-paul-blanc.netlify.app/images/og-image.png"
    />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="675" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:image"
      content="https://portfolio-paul-blanc.netlify.app/images/og-image.png"
    />

    <link
      rel="preload"
      href="/fonts/PPEditorialNew-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/PPEditorialNew-Ultralight.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/PPFraktionMono-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/PPFraktionMono-Bold.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/Bigger-Display.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
  </head>

  <body data-page="home">
    <div class="bg-luxury" aria-hidden="true">
      <canvas class="bg-luxury__canvas js-luxury-canvas"></canvas>
      <div class="bg-luxury__noise"></div>
      <div class="bg-luxury__glow bg-luxury__glow--gold"></div>
      <div class="bg-luxury__glow bg-luxury__glow--sapphire"></div>
      <div class="bg-luxury__glow bg-luxury__glow--violet"></div>
    </div>
    <div class="site-wrapper js-site-wrapper" style="opacity: 0;">
      <SiteHead />

      <SHero />

      <SAbout />

      <ASeparator style="secondary" />

      <SWork />

      <ASeparator style="secondary" />

      <SMyWay />

      <SCTA />

      <SiteFoot />
    </div><!-- .site-wrapper -->

    <div class="site-intro js-intro">
      <canvas class="intro-canvas js-intro-canvas" aria-hidden="true"></canvas>
      <div class="intro-glow"></div>
      <div class="intro-inner">
        <div class="intro-line js-line"></div>
        <h1 class="intro-name" aria-label="Paul Blanc">
          <span class="intro-char js-char"><span class="js-char-inner">P</span></span>
          <span class="intro-char js-char"><span class="js-char-inner">A</span></span>
          <span class="intro-char js-char"><span class="js-char-inner">U</span></span>
          <span class="intro-char js-char"><span class="js-char-inner">L</span></span>
          <span class="intro-char intro-char--space">&thinsp;&thinsp;</span>
          <span class="intro-char js-char"><span class="js-char-inner">B</span></span>
          <span class="intro-char js-char"><span class="js-char-inner">L</span></span>
          <span class="intro-char js-char"><span class="js-char-inner">A</span></span>
          <span class="intro-char js-char"><span class="js-char-inner">N</span></span>
          <span class="intro-char js-char"><span class="js-char-inner">C</span></span>
        </h1>
        <p class="intro-sub js-sub">Développeur &middot; Motion Design</p>
      </div><!-- .intro-inner -->
      <div class="intro-corners">
        <span class="intro-corner js-corner"></span>
        <span class="intro-corner js-corner"></span>
        <span class="intro-corner js-corner"></span>
        <span class="intro-corner js-corner"></span>
      </div>
      <div class="intro-loader">
        <span class="js-loader-num">00</span>%
      </div>
    </div><!-- .site-intro -->

    <div class="site-mount js-mount"></div>
    <div class="site-contrast-mask js-contrast-mask"></div>

    <SiteScrollbar />
    <SiteTutorial />
    <SiteCursor />
  </body>

  <script>
    import Emitter from '../utils/Emitter'
    import Ticker from '../utils/Ticker'

    import Lenis from 'lenis'

    import { gsap } from 'gsap'
    import { ScrollTrigger } from 'gsap/ScrollTrigger'
    gsap.registerPlugin(ScrollTrigger)


    declare global {
      interface Window {
        safeWidth: number
        safeHeight: number
        maxScrollTop: number
        scrollProgress: number
        lenis: any
      }
    }

    class Site {
      timeouts: any = {
        resizeThrottle: null,
      }

      windowWidth: number
      windowHeight: number
      clientWidth: number
      clientHeight: number

      isScrolling: boolean = false

      lenis: any

      /**
       * Constructor
       */
      constructor() {
        // OS class
        let os = 'unknown'
        if (navigator.userAgent.indexOf('Win') !== -1) {
          os = 'windows'
        } else if (navigator.userAgent.indexOf('Android') !== -1) {
          os = 'android'
        } else if (navigator.userAgent.indexOf('Mac') !== -1) {
          os = 'mac'
        } else if (navigator.userAgent.indexOf('Linux') !== -1) {
          os = 'linux'
        }
        document.documentElement.classList.add(`is-${os}`)

        // Browser class
        let browser = 'unknown'
        if (navigator.userAgent.indexOf('Firefox') !== -1) {
          browser = 'firefox'
        } else if (navigator.userAgent.indexOf('Chrome') !== -1) {
          browser = 'chrome'
        } else if (navigator.userAgent.indexOf('Safari') !== -1) {
          browser = 'safari'
        }
        document.documentElement.classList.add(`is-${browser}`)

        this.bindEvents()
      }

      /**
       * Initialization
       */
      init() {
        this.initLenis()

        Ticker.init()

        this.onResize()
        Ticker.nextTick(this.intro, this)
      }

      /**
       * Bind events
       */
      bindEvents() {
        window.addEventListener('resize', this.resizeThrottle.bind(this))
        window.addEventListener('scroll', this.onScroll.bind(this), {
          passive: true,
        })
        window.addEventListener('mousemove', this.onMouseMove.bind(this), {
          passive: true,
        })

        Emitter.on('updateViewport', this.onResize, this, true)

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              entry.target.dispatchEvent(
                new CustomEvent('intersect', {
                  detail: { isIntersecting: entry.isIntersecting },
                }),
              )

              if (entry.isIntersecting) {
                entry.target.classList.add('is-in-view')
                entry.target.classList.remove(
                  'is-out-of-view',
                  'is-out-of-view-top',
                  'is-out-of-view-bottom',
                )
              } else {
                entry.target.classList.remove('is-in-view')
                entry.target.classList.add('is-out-of-view')

                entry.target.classList.toggle(
                  'is-out-of-view-top',
                  entry.boundingClientRect.top < 0,
                )
                entry.target.classList.toggle(
                  'is-out-of-view-bottom',
                  entry.boundingClientRect.top > 0,
                )
              }
            })
          },
          {
            threshold: 0,
          },
        )

        document.querySelectorAll('[data-intersect]').forEach((el) => {
          observer.observe(el)
        })

        // Site loaded event
        if (document.readyState === 'complete') {
          this.siteLoaded()
        } else {
          window.addEventListener('load', this.siteLoaded, { once: true })
        }

        this.onScroll()
      }

      /**
       * Init lenis
       */
      initLenis() {
        const lenis = new Lenis()

        lenis.on('scroll', ScrollTrigger.update)

        gsap.ticker.add((time) => {
          lenis.raf(time * 1000)
        })

        gsap.ticker.lagSmoothing(0)

        window.lenis = lenis
        this.lenis = lenis
      }

      /**
       * Set loaded class
       */
      siteLoaded() {
        document.documentElement.classList.add('is-loaded')

        Emitter.emit('siteLoaded')
      }

      /**
       * Resize throttle
       */
      resizeThrottle() {
        clearTimeout(this.timeouts.resizeThrottle)

        this.timeouts.resizeThrottle = setTimeout(() => {
          Ticker.nextTick(this.onResize, this)
        }, 200)
      }

      /**
       * Resize handler
       */
      onResize() {
        const newWidth = window.innerWidth
        let widthChanged = false
        if (this.windowWidth !== newWidth) {
          if (this.windowWidth !== undefined) {
            widthChanged = true
          }

          this.windowWidth = newWidth
          this.clientWidth = document.body.clientWidth
        }

        const newHeight = window.innerHeight
        let heightChanged = false
        if (this.windowHeight !== newHeight) {
          if (this.windowHeight !== undefined) {
            heightChanged = true
          }

          this.windowHeight = newHeight
          this.clientHeight = document.body.clientHeight
        }

        window.safeWidth = newWidth
        window.safeHeight = newHeight

        window.maxScrollTop = document.body.scrollHeight - window.safeHeight

        this.setScrollProgress()

        Emitter.emit('resize', widthChanged, heightChanged)
      }

      /**
       * Scroll handler
       */
      onScroll() {
        this.setScrollProgress()

        Ticker.nextTick(() => {
          Emitter.emit('scroll', window.scrollY)
        })
      }

      /**
       * Set scroll progress
       */
      setScrollProgress() {
        window.scrollProgress = window.scrollY / window.maxScrollTop
      }

      /**
       * Mouse move handler
       */
      onMouseMove(e) {
        Emitter.emit('mousemove', e.clientX, e.clientY)
      }

      /**
       * Intro — cinematic motion design reveal (pure CSS + GSAP)
       */
      intro() {
        const wrapper  = document.querySelector('.js-site-wrapper') as HTMLElement
        const introEl  = document.querySelector('.js-intro')        as HTMLElement
        const mount    = document.querySelector('.js-mount')        as HTMLElement

        wrapper.style.opacity = ''

        const chars      = introEl.querySelectorAll<HTMLElement>('.js-char-inner')
        const sub        = introEl.querySelector<HTMLElement>('.js-sub')!
        const line       = introEl.querySelector<HTMLElement>('.js-line')!
        const corners    = introEl.querySelectorAll<HTMLElement>('.js-corner')
        const loaderNum  = introEl.querySelector<HTMLElement>('.js-loader-num')!
        const glow       = introEl.querySelector<HTMLElement>('.intro-glow')!

        const cleanup = () => {
          if (!introEl.parentNode) return
          introEl.remove()
          document.documentElement.classList.remove('is-scroll-blocked')
          Ticker.nextTick(() => { Emitter.emit('updateViewport') })
        }

        const counter = { val: 0 }

        const tl = gsap.timeline({ onComplete: cleanup })

        tl
          // ── Initial states ─────────────────────────────────────────
          .set(chars,   { yPercent: 115 })
          .set(sub,     { opacity: 0, letterSpacing: '-0.06em' })
          .set(line,    { scaleX: 0, transformOrigin: 'center center' })
          .set(corners, { opacity: 0, scale: 0.7 })
          .set(glow,    { opacity: 0, scale: 0.6 })

          // ── Ambient glow blooms in ──────────────────────────────────
          .to(glow, { opacity: 1, scale: 1, duration: 1.6, ease: 'power2.out' }, 0)

          // ── Corner brackets appear ─────────────────────────────────
          .to(corners, {
            opacity: 1, scale: 1,
            duration: 0.55, ease: 'power3.out',
            stagger: { amount: 0.15, from: 'random' },
          }, 0.1)

          // ── Loading counter (00 → 100) ─────────────────────────────
          .to(counter, {
            val: 100,
            duration: 2.2,
            ease: 'power1.inOut',
            onUpdate: () => {
              loaderNum.textContent = String(Math.round(counter.val)).padStart(2, '0')
            },
          }, 0.1)

          // ── Line draws in from center ──────────────────────────────
          .to(line, { scaleX: 1, duration: 0.7, ease: 'power3.inOut' }, 0.25)

          // ── Letters slide up from clip masks ───────────────────────
          .to(chars, {
            yPercent: 0,
            duration: 0.85,
            ease: 'power3.out',
            stagger: 0.045,
          }, 0.5)

          // ── Subtitle letter-spacing expands ────────────────────────
          .to(sub, {
            opacity: 1,
            letterSpacing: '0.32em',
            duration: 1.1,
            ease: 'power2.out',
          }, 0.95)

          // ── Hold ───────────────────────────────────────────────────

          // ── Glow pulses brighter before exit ──────────────────────
          .to(glow, { opacity: 0.5, scale: 1.15, duration: 0.4, ease: 'power2.in' }, 2.25)

          // ── Letters exit upward ────────────────────────────────────
          .to(chars, {
            yPercent: -115,
            duration: 0.55,
            ease: 'power3.in',
            stagger: 0.028,
          }, 2.45)
          .to(sub,  { opacity: 0, y: -6, duration: 0.38, ease: 'power2.in' }, 2.45)
          .to(line, { scaleX: 0,         duration: 0.42, ease: 'power3.in' }, 2.55)

          // ── Corners & loader fade out ──────────────────────────────
          .to(corners, {
            opacity: 0, scale: 0.8,
            duration: 0.3, ease: 'power2.in',
            stagger: 0.04,
          }, 2.5)
          .to('.intro-loader', { opacity: 0, duration: 0.3, ease: 'power2.in' }, 2.5)
          .to(glow,   { opacity: 0, scale: 0.5, duration: 0.5, ease: 'power2.in' }, 2.6)
          .call(() => { document.dispatchEvent(new CustomEvent('intro-3d-destroy')) }, [], 2.65)

          // ── Show border frame ──────────────────────────────────────
          .call(() => { mount.style.opacity = '1' }, [], 2.85)

          // ── Curtain: intro slides up revealing portfolio ───────────
          .to(introEl, { yPercent: -100, duration: 0.78, ease: 'power3.inOut' }, 2.9)

          // ── Fire intro event at mid-curtain ────────────────────────
          .call(() => { document.dispatchEvent(new CustomEvent('intro')) }, [], 3.3)

        // Safety fallback
        setTimeout(cleanup, 8000)
      }
    }

    const site = new Site()

    // Site init on DOM ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', site.init, { once: true })
    } else {
      site.init()
    }
  </script>

  <script>
    // ── Luxury background canvas — particles + grid ──────────────────────
    const luxCanvas = document.querySelector('.js-luxury-canvas') as HTMLCanvasElement
    if (luxCanvas) {
      const lctx = luxCanvas.getContext('2d')!

      function luxResize() {
        luxCanvas.width  = window.innerWidth
        luxCanvas.height = window.innerHeight
      }
      luxResize()
      window.addEventListener('resize', luxResize, { passive: true })

      const GOLD   = { r: 201, g: 168, b: 76  }
      const SILVER = { r: 190, g: 200, b: 215 }
      const VIOLET = { r: 192, g: 38,  b: 211 }

      interface LuxParticle {
        x: number; y: number; r: number
        vx: number; vy: number; a: number
        color: { r: number; g: number; b: number }
      }

      const COUNT = 110
      const pts: LuxParticle[] = []

      function mkParticle(): LuxParticle {
        const roll = Math.random()
        const color = roll < 0.45 ? GOLD : roll < 0.75 ? SILVER : VIOLET
        return {
          x: Math.random() * luxCanvas.width,
          y: Math.random() * luxCanvas.height,
          r: 0.3 + Math.random() * 1.1,
          vx: (Math.random() - 0.5) * 0.12,
          vy: (Math.random() - 0.5) * 0.12,
          a: 0.15 + Math.random() * 0.45,
          color,
        }
      }
      for (let i = 0; i < COUNT; i++) pts.push(mkParticle())

      // Mouse parallax on glows
      let mx = 0, my = 0
      window.addEventListener('mousemove', (e) => {
        mx = e.clientX / window.innerWidth  - 0.5
        my = e.clientY / window.innerHeight - 0.5
      }, { passive: true })

      const goldEl    = document.querySelector('.bg-luxury__glow--gold')    as HTMLElement
      const sapphEl   = document.querySelector('.bg-luxury__glow--sapphire') as HTMLElement
      const violetEl  = document.querySelector('.bg-luxury__glow--violet')   as HTMLElement

      let ogx = 0, ogy = 0

      function luxTick() {
        requestAnimationFrame(luxTick)

        lctx.clearRect(0, 0, luxCanvas.width, luxCanvas.height)

        // Subtle grid
        const gap = 90
        lctx.beginPath()
        lctx.strokeStyle = 'rgba(255,255,255,0.016)'
        lctx.lineWidth = 0.5
        for (let x = 0; x <= luxCanvas.width; x += gap) {
          lctx.moveTo(x, 0); lctx.lineTo(x, luxCanvas.height)
        }
        for (let y = 0; y <= luxCanvas.height; y += gap) {
          lctx.moveTo(0, y); lctx.lineTo(luxCanvas.width, y)
        }
        lctx.stroke()

        // Particles
        pts.forEach((p) => {
          p.x += p.vx; p.y += p.vy
          if (p.x < -5 || p.x > luxCanvas.width + 5 || p.y < -5 || p.y > luxCanvas.height + 5) {
            Object.assign(p, mkParticle(), { x: Math.random() * luxCanvas.width, y: Math.random() * luxCanvas.height })
          }
          lctx.beginPath()
          lctx.arc(p.x, p.y, p.r, 0, Math.PI * 2)
          lctx.fillStyle = `rgba(${p.color.r},${p.color.g},${p.color.b},${p.a})`
          lctx.fill()
        })

        // Connections
        for (let i = 0; i < pts.length; i++) {
          for (let j = i + 1; j < pts.length; j++) {
            const dx = pts[i].x - pts[j].x
            const dy = pts[i].y - pts[j].y
            const d  = Math.sqrt(dx * dx + dy * dy)
            if (d < 130) {
              lctx.beginPath()
              lctx.moveTo(pts[i].x, pts[i].y)
              lctx.lineTo(pts[j].x, pts[j].y)
              lctx.strokeStyle = `rgba(201,168,76,${0.045 * (1 - d / 130)})`
              lctx.lineWidth = 0.4
              lctx.stroke()
            }
          }
        }

        // Glow parallax (slow lerp)
        ogx += (mx - ogx) * 0.04
        ogy += (my - ogy) * 0.04
        if (goldEl)   goldEl.style.transform   = `translate(${ogx * 40}px, ${ogy * 30}px)`
        if (sapphEl)  sapphEl.style.transform  = `translate(${ogx * -30}px, ${ogy * -20}px)`
        if (violetEl) violetEl.style.transform = `translate(${ogx * 20}px, ${ogy * 40}px)`
      }
      luxTick()
    }
  </script>

  <script>
    import * as THREE from 'three'

    const canvas = document.querySelector('.js-intro-canvas')
    if (!canvas) throw new Error('intro canvas not found')

    const W = window.innerWidth
    const H = window.innerHeight

    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true })
    renderer.setSize(W, H)
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5))

    const scene  = new THREE.Scene()
    const camera = new THREE.PerspectiveCamera(55, W / H, 0.1, 100)
    camera.position.z = 5.5

    // ── Outer wireframe geodesic sphere ────────────────────────────────
    const geoOuter = new THREE.IcosahedronGeometry(3.2, 5)
    const matOuter = new THREE.MeshBasicMaterial({
      color: 0x7c3aed,
      wireframe: true,
      transparent: true,
      opacity: 0.13,
    })
    const meshOuter = new THREE.Mesh(geoOuter, matOuter)
    scene.add(meshOuter)

    // ── Inner geodesic sphere ───────────────────────────────────────────
    const geoInner = new THREE.IcosahedronGeometry(2.0, 3)
    const matInner = new THREE.MeshBasicMaterial({
      color: 0xc4b5fd,
      wireframe: true,
      transparent: true,
      opacity: 0.09,
    })
    const meshInner = new THREE.Mesh(geoInner, matInner)
    scene.add(meshInner)

    // ── Equatorial ring ─────────────────────────────────────────────────
    const geoRing = new THREE.TorusGeometry(3.8, 0.004, 2, 180)
    const matRing = new THREE.MeshBasicMaterial({
      color: 0xa78bfa,
      transparent: true,
      opacity: 0.35,
    })
    const ring = new THREE.Mesh(geoRing, matRing)
    ring.rotation.x = Math.PI / 2.6
    scene.add(ring)

    // ── Particle field ──────────────────────────────────────────────────
    const COUNT = 700
    const pPos  = new Float32Array(COUNT * 3)
    const pCol  = new Float32Array(COUNT * 3)
    const colors = [
      new THREE.Color(0xa78bfa),
      new THREE.Color(0x8b5cf6),
      new THREE.Color(0xc4b5fd),
      new THREE.Color(0xffffff),
    ]
    for (let i = 0; i < COUNT; i++) {
      const r     = 4.5 + Math.random() * 12
      const theta = Math.random() * Math.PI * 2
      const phi   = Math.acos(2 * Math.random() - 1)
      pPos[i*3]   = r * Math.sin(phi) * Math.cos(theta)
      pPos[i*3+1] = r * Math.sin(phi) * Math.sin(theta)
      pPos[i*3+2] = (Math.random() - 0.5) * 14
      const c = colors[Math.floor(Math.random() * colors.length)]
      pCol[i*3]   = c.r
      pCol[i*3+1] = c.g
      pCol[i*3+2] = c.b
    }
    const pGeo = new THREE.BufferGeometry()
    pGeo.setAttribute('position', new THREE.BufferAttribute(pPos, 3))
    pGeo.setAttribute('color',    new THREE.BufferAttribute(pCol, 3))
    const pMat = new THREE.PointsMaterial({
      size: 0.028,
      vertexColors: true,
      transparent: true,
      opacity: 0.5,
      sizeAttenuation: true,
    })
    scene.add(new THREE.Points(pGeo, pMat))

    // ── Mouse parallax ──────────────────────────────────────────────────
    let tX = 0, tY = 0, oX = 0, oY = 0
    const onMouse = (e) => {
      tX = (e.clientX / window.innerWidth  - 0.5) * 0.55
      tY = (e.clientY / window.innerHeight - 0.5) * 0.35
    }
    window.addEventListener('mousemove', onMouse, { passive: true })

    // ── Render loop ─────────────────────────────────────────────────────
    let raf
    const animate = () => {
      raf = requestAnimationFrame(animate)
      const t = performance.now() * 0.001

      meshOuter.rotation.y  = t * 0.09
      meshOuter.rotation.x  = t * 0.04
      meshInner.rotation.y  = -t * 0.14
      meshInner.rotation.z  = t * 0.06
      ring.rotation.z       = t * 0.07

      oX += (tX - oX) * 0.035
      oY += (tY - oY) * 0.035
      scene.rotation.y = oX
      scene.rotation.x = -oY

      renderer.render(scene, camera)
    }
    animate()

    // ── Cleanup ──────────────────────────────────────────────────────────
    document.addEventListener('intro-3d-destroy', () => {
      cancelAnimationFrame(raf)
      window.removeEventListener('mousemove', onMouse)
      renderer.dispose()
      geoOuter.dispose(); matOuter.dispose()
      geoInner.dispose(); matInner.dispose()
      geoRing.dispose();  matRing.dispose()
      pGeo.dispose();     pMat.dispose()
    }, { once: true })
  </script>

