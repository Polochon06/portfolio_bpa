  <script>
    import Lenis from 'lenis'
    import { gsap } from 'gsap'
    import { ScrollTrigger } from 'gsap/ScrollTrigger'
    gsap.registerPlugin(ScrollTrigger)

    // ── LENIS ─────────────────────────────────────────────────────────
    const lenis = new Lenis({
      duration: 2.2,
      easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      touchMultiplier: 1.8,
    })
    lenis.on('scroll', ScrollTrigger.update)
    gsap.ticker.add((time: number) => lenis.raf(time * 1000))
    gsap.ticker.lagSmoothing(0)

    // ── VIDEO MANAGEMENT ──────────────────────────────────────────────
    const videos = Array.from(document.querySelectorAll('.bg-vid')) as HTMLVideoElement[]
    let currentVid = 0

    function activateVideo(index: number) {
      if (index === currentVid) return
      const next = videos[index]
      if (!next) return
      // Lazy load
      if (next.preload === 'none') {
        next.preload = 'auto'
        next.load()
      }
      const prev = videos[currentVid]
      next.classList.add('active')
      prev.classList.remove('active')
      currentVid = index
      next.play().catch(() => {})
    }

    // Preload next video
    function preloadNext(i: number) {
      const next = videos[i + 1]
      if (next && next.preload === 'none') {
        next.preload = 'auto'
        next.load()
      }
    }

    // ── SCENE SCROLL TRIGGERS ─────────────────────────────────────────
    const scenes = Array.from(document.querySelectorAll('.scene')) as HTMLElement[]
    const navDots = Array.from(document.querySelectorAll('.nav-dot')) as HTMLElement[]
    const progressBar = document.getElementById('progress-bar') as HTMLElement

    // Update progress bar
    lenis.on('scroll', ({ progress }: { progress: number }) => {
      progressBar.style.width = `${progress * 100}%`
    })

    scenes.forEach((scene, i) => {
      const vidIndex = parseInt(scene.dataset.vid || '1') - 1

      ScrollTrigger.create({
        trigger: scene,
        start: 'top 55%',
        end: 'bottom 45%',
        onEnter: () => {
          activateVideo(vidIndex)
          preloadNext(vidIndex)
          navDots.forEach((d, j) => d.classList.toggle('active', j === i))
        },
        onEnterBack: () => {
          activateVideo(vidIndex)
          navDots.forEach((d, j) => d.classList.toggle('active', j === i))
        },
      })

      // Cinematic parallax on scene content
      const content = scene.querySelector('.scene-content')
      if (content) {
        gsap.fromTo(content,
          { opacity: 0, y: 35 },
          {
            opacity: 1, y: 0,
            duration: 1,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: scene,
              start: 'top 65%',
              toggleActions: 'play none none reverse',
            }
          }
        )
      }

      // Zoom effect on background video
      const vid = videos[vidIndex]
      if (vid) {
        gsap.fromTo(vid,
          { scale: 1.08 },
          {
            scale: 1.0,
            ease: 'none',
            scrollTrigger: {
              trigger: scene,
              start: 'top bottom',
              end: 'bottom top',
              scrub: 2.5,
            }
          }
        )
      }
    })

    // ── NAV DOTS CLICK ────────────────────────────────────────────────
    navDots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const sceneIndex = parseInt(dot.dataset.scene || '0')
        lenis.scrollTo(scenes[sceneIndex], { duration: 2.5, easing: (t: number) => 1 - Math.pow(1 - t, 4) })
      })
    })

    // ── LETTERBOX REMOVE ON SCROLL ────────────────────────────────────
    ScrollTrigger.create({
      trigger: scenes[1],
      start: 'top 80%',
      onEnter: () => document.body.classList.remove('cinematic'),
      onLeaveBack: () => document.body.classList.add('cinematic'),
    })
  </script>

