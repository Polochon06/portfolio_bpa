      </ul>
      <div class="proj-tags fade-in">
        <span class="proj-tag">Java 17</span>
        <span class="proj-tag">MySQL</span>
        <span class="proj-tag">MVC / DAO</span>
        <span class="proj-tag">RBAC</span>
        <span class="proj-tag">JWT</span>
      </div>
      <a href="/portfolio_bpa/mt-conges" class="scene-cta fade-in">
        Voir le projet <span class="arr">↗</span>
      </a>
    </div>
  </section>

  <!-- S5 · GYMNOVA ═══════════════════════════════════════════════════ -->
  <section class="scene" id="s5" data-vid="5" data-status="Projet 02 — Gymnova">
    <div class="scene-inner">
      <div class="proj-num-bg fade-in">02</div>
      <div class="proj-meta fade-in">React · E-Commerce · 2024</div>
      <h2 class="scene-title proj-title">
        <span class="tl"><span class="ti">Gym-</span></span>
        <span class="tl"><span class="ti is-em">nova</span></span>
      </h2>
      <p class="scene-body fade-in">Plateforme e-commerce complète — 50+ produits, panier, Stripe, back-office admin.</p>
      <ul class="feat-list fade-in">
        <li>Catalogue 50+ produits avec filtres avancés</li>
        <li>Panier temps réel + Stripe intégré</li>
        <li>Auth JWT, espace client, historique commandes</li>
        <li>Back-office admin : stocks, commandes, analytics</li>
