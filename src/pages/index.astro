  <script>
    import Lenis from 'lenis'
    import { gsap } from 'gsap'
    import { ScrollTrigger } from 'gsap/ScrollTrigger'
    gsap.registerPlugin(ScrollTrigger)

    // ── LENIS ──────────────────────────────────────────────────────────
    const lenis = new Lenis({
      duration: 2.0,
      easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      touchMultiplier: 1.6,
    })
    lenis.on('scroll', ScrollTrigger.update)
    gsap.ticker.add((time: number) => lenis.raf(time * 1000))
    gsap.ticker.lagSmoothing(0)

    // ── VIDEOS ─────────────────────────────────────────────────────────
    const videos = Array.from(document.querySelectorAll<HTMLVideoElement>('.bg-vid'))
    let currentVid = 0
    let pauseTimers: ReturnType<typeof setTimeout>[] = []

    // Loop each video on end
    videos.forEach(vid => {
      vid.addEventListener('ended', () => {
        vid.currentTime = 0
        vid.play().catch(() => {})
      })
    })

    function activateVideo(index: number) {
      if (index === currentVid) return
      const next = videos[index]
      const prev = videos[currentVid]
      if (!next) return

      // Clear any pending pause for prev
      pauseTimers.forEach(t => clearTimeout(t))
      pauseTimers = []

      // Lazy load
      if (next.preload === 'none') {
        next.preload = 'auto'
        next.load()
      }
      // Preload the one after
      const after = videos[index + 1]
      if (after && after.preload === 'none') {
        after.preload = 'metadata'
        after.load()
      }

      // Reset + play next
      next.currentTime = 0
      next.play().catch(() => {})
      next.classList.add('active')
      prev.classList.remove('active')

      // Pause prev after crossfade completes (1.4s)
      pauseTimers.push(setTimeout(() => {
        if (!prev.classList.contains('active')) prev.pause()
      }, 1500))

      currentVid = index
    }

    // ── SCENES ─────────────────────────────────────────────────────────
    const scenes   = Array.from(document.querySelectorAll<HTMLElement>('.scene'))
    const navDots  = Array.from(document.querySelectorAll<HTMLElement>('.nav-dot'))
    const barStatus = document.getElementById('bar-status')!
    const progressBar = document.getElementById('progress-bar')!

    // Progress bar
    lenis.on('scroll', ({ progress }: { progress: number }) => {
      progressBar.style.width = `${progress * 100}%`
    })

    scenes.forEach((scene, i) => {
      const vidIndex = parseInt(scene.dataset.vid ?? '1') - 1
      const status   = scene.dataset.status ?? ''

      // ── Activate video + nav dot when scene is centred ──
      ScrollTrigger.create({
        trigger: scene,
        start: 'top 58%',
        end:   'bottom 42%',
        onEnter: () => {
          activateVideo(vidIndex)
          navDots.forEach((d, j) => d.classList.toggle('active', j === i))
          if (barStatus) barStatus.textContent = status
        },
        onEnterBack: () => {
          activateVideo(vidIndex)
          navDots.forEach((d, j) => d.classList.toggle('active', j === i))
          if (barStatus) barStatus.textContent = status
        },
      })

      // ── Staggered text reveals ──
      const reveals = Array.from(scene.querySelectorAll<HTMLElement>('[data-reveal]'))
      if (reveals.length) {
        gsap.set(reveals, { opacity: 0, y: 28 })
        ScrollTrigger.create({
          trigger: scene,
          start: 'top 62%',
          onEnter: () => {
            gsap.to(reveals, {
              opacity: 1, y: 0,
              duration: 1.1,
              stagger: 0.13,
              ease: 'power3.out',
            })
          },
          onLeaveBack: () => {
            gsap.to(reveals, {
              opacity: 0, y: 28,
              duration: 0.6,
              stagger: 0.06,
              ease: 'power2.in',
            })
          },
        })
      }

      // ── Subtle bg scale parallax ──
      gsap.fromTo(videos[vidIndex],
        { scale: 1.08 },
        {
          scale: 1.0,
          ease: 'none',
          scrollTrigger: {
            trigger: scene,
            start: 'top bottom',
            end:   'bottom top',
            scrub: 2,
          },
        }
      )
    })

    // ── NAV DOTS ───────────────────────────────────────────────────────
    navDots.forEach(dot => {
      dot.addEventListener('click', () => {
        const idx = parseInt(dot.dataset.scene ?? '0')
        lenis.scrollTo(scenes[idx], {
          duration: 2.4,
          easing: (t: number) => 1 - Math.pow(1 - t, 4),
        })
      })
    })

    // ── LETTERBOX — remove on S2 ───────────────────────────────────────
    ScrollTrigger.create({
      trigger: scenes[1],
      start: 'top 80%',
      onEnter:     () => document.body.classList.remove('cinematic'),
      onLeaveBack: () => document.body.classList.add('cinematic'),
    })

    // ── SCROLL CUE — fade out on scroll ───────────────────────────────
    gsap.to('.scroll-cue', {
      opacity: 0,
      scrollTrigger: {
        trigger: '#s1',
        start: 'top top',
        end:   '+=180',
        scrub: true,
      },
    })
  </script>

