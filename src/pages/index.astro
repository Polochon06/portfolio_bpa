  <!-- S1 · INTRO ════════════════════════════════════════════════════ -->
  <section class="scene active" id="s1" data-vid="1" data-status="Développeur Créatif">
    <div class="scene-inner">
      <p class="hero-eyebrow">Normandie · France · 2025</p>
