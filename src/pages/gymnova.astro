---
import ProjectLayout from '../layouts/ProjectLayout.astro'
import heroBgImg from '../assets/bg-gymnova.jpg'
---

<ProjectLayout
  title="Gymnova Shop | E-Commerce React"
  description="Site e-commerce de vente de materiel de gymnastique. React 18, Node.js, Express, MySQL, Stripe."
  heroLabel="Projet 02 · BTS SIO SLAM · 2024"
  heroSub="Site e-commerce complet de vente de materiel de gymnastique professionnel — catalogue, panier, paiement Stripe integre."
  techTags={["React 18", "Node.js", "Express", "MySQL", "Stripe", "JWT"]}
  heroBg={heroBgImg.src}
>
  <Fragment slot="hero-title">GYMNOVA<br/>SHOP</Fragment>

  <!-- ═══ 01 · STACK & CONTEXTE ════════════════════════════════════ -->
  <section class="p-section" data-reveal>
    <div class="p-section__header">
      <span class="p-section__num">01</span>
      <h2 class="p-section__title">Stack & Contexte</h2>
      <div class="p-section__line"></div>
    </div>

    <div class="p-grid">
      <div>
        <div class="p-body">
          <p>
            Gymnova Shop est un site e-commerce complet developpe dans le cadre
            du <strong>BTS SIO SLAM</strong>. Inspire de la marque Gymnova (fabricant
            francais d'equipements), le site propose un catalogue de <strong>~50 references</strong>
            reparties en 8 categories.
          </p>
          <p>
            Le projet couvre l'ensemble du parcours client : navigation avec filtres,
            fiche produit, gestion du panier, checkout avec <strong>paiement Stripe</strong>,
            suivi des commandes. Un back-office admin gere les statuts des commandes.
          </p>
          <p>
            L'architecture repose sur une <strong>SPA React 18</strong> cote front
            communicant avec une <strong>API REST Express</strong> (port 5000), une base
            MySQL a 8 tables, et l'authentification via <strong>JWT + bcryptjs</strong>.
          </p>
        </div>

        <div class="p-stack" style="margin-top: 2.5rem;">
          {["React 18", "React Router", "Node.js", "Express", "MySQL", "Stripe.js", "JWT", "bcryptjs", "Axios", "CORS"].map(t => (
            <span class="p-tag">{t}</span>
          ))}
        </div>
      </div>

      <div class="p-card">
        <span class="p-card__label">API Endpoints</span>
        <div class="p-mono-block">
          <div class="p-mono-block__group">
            <div class="p-mono-block__title">/api/auth</div>
            <div><span class="p-method p-method--post">POST</span>/register</div>
            <div><span class="p-method p-method--post">POST</span>/login</div>
          </div>
          <div class="p-mono-block__group">
            <div class="p-mono-block__title">/api/products</div>
            <div><span class="p-method p-method--get">GET</span>/ (liste + filtres)</div>
            <div><span class="p-method p-method--get">GET</span>/:id</div>
          </div>
          <div class="p-mono-block__group">
            <div class="p-mono-block__title">/api/cart</div>
            <div><span class="p-method p-method--get">GET</span>/</div>
            <div><span class="p-method p-method--post">POST</span>/add</div>
            <div><span class="p-method p-method--put">PUT</span>/update</div>
            <div><span class="p-method p-method--delete">DEL</span>/remove/:id</div>
          </div>
          <div class="p-mono-block__group">
            <div class="p-mono-block__title">/api/orders</div>
            <div><span class="p-method p-method--post">POST</span>/create</div>
            <div><span class="p-method p-method--get">GET</span>/ (historique)</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FEATURED VISUAL ═════════════════════════════════════════ -->
  <div class="p-featured" data-reveal>
    <img src={heroBgImg.src} alt="Gymnova Shop — Salle de sport professionnelle" loading="lazy" />
    <div class="p-featured__caption">Interface E-Commerce · React 18 + Stripe · ~50 References</div>
  </div>

  <!-- ═══ 02 · CATALOGUE ═══════════════════════════════════════════ -->
  <section class="p-section" data-reveal>
    <div class="p-section__header">
      <span class="p-section__num">02</span>
      <h2 class="p-section__title">Catalogue Produits</h2>
      <div class="p-section__line"></div>
    </div>

    <p class="p-body" style="max-width: 600px; margin-bottom: 3rem;">
      <span style="opacity:0.6">~50 references de materiel de gymnastique professionnel reparties en 8 categories.</span>
    </p>

    <div class="p-catalogue">
      <div class="p-cat-item">
        <span class="p-cat-icon">🤸</span>
        <span class="p-cat-name">Floor Mats</span>
        <span class="p-cat-price">149 – 15 999 €</span>
      </div>
      <div class="p-cat-item">
        <span class="p-cat-icon">⚖️</span>
        <span class="p-cat-name">Poutres</span>
        <span class="p-cat-price">79 – 3 299 €</span>
      </div>
      <div class="p-cat-item">
        <span class="p-cat-icon">🏋️</span>
        <span class="p-cat-name">Barres</span>
        <span class="p-cat-price">24 – 5 999 €</span>
      </div>
      <div class="p-cat-item">
        <span class="p-cat-icon">🦘</span>
        <span class="p-cat-name">Trampolines</span>
        <span class="p-cat-price">79 – 12 999 €</span>
      </div>
      <div class="p-cat-item">
        <span class="p-cat-icon">⭕</span>
        <span class="p-cat-name">Anneaux</span>
        <span class="p-cat-price">149 – 4 999 €</span>
      </div>
      <div class="p-cat-item">
        <span class="p-cat-icon">🐴</span>
        <span class="p-cat-name">Cheval d'Arcons</span>
        <span class="p-cat-price">299 – 3 299 €</span>
      </div>
      <div class="p-cat-item">
        <span class="p-cat-icon">🏃</span>
        <span class="p-cat-name">Saut</span>
        <span class="p-cat-price">599 – 3 499 €</span>
      </div>
      <div class="p-cat-item">
        <span class="p-cat-icon">🎒</span>
        <span class="p-cat-name">Accessoires</span>
        <span class="p-cat-price">12 – 189 €</span>
      </div>
    </div>
  </section>

  <!-- ═══ 03 · FONCTIONNALITES ═════════════════════════════════════ -->
  <section class="p-section" data-reveal>
    <div class="p-section__header">
      <span class="p-section__num">03</span>
      <h2 class="p-section__title">Fonctionnalites</h2>
      <div class="p-section__line"></div>
    </div>

    <div class="p-features">
      <div class="p-card">
        <span class="p-badge p-badge--ux">Frontend</span>
        <h3 class="p-card__title">Catalogue & Filtres</h3>
        <p class="p-card__body">
          Navigation avec <strong style="color:var(--p-text)">filtrage par categorie</strong>
          et recherche textuelle. Fiche produit complete avec images, description et avis clients.
        </p>
      </div>

      <div class="p-card">
        <span class="p-badge p-badge--arch">Paiement</span>
        <h3 class="p-card__title">Checkout Stripe</h3>
        <p class="p-card__body">
          Integration <strong style="color:var(--p-text)">Stripe.js</strong> pour le paiement
          securise. Mode demo disponible sans cle API. Formulaire d'adresse de livraison integre.
        </p>
      </div>

      <div class="p-card">
        <span class="p-badge p-badge--solution">Backend</span>
        <h3 class="p-card__title">Auth JWT</h3>
        <p class="p-card__body">
          Authentification complete avec <strong style="color:var(--p-text)">JSON Web Tokens</strong>
          (7 jours). Inscription, connexion, gestion du profil. Hash bcryptjs.
        </p>
      </div>

      <div class="p-card">
        <span class="p-badge p-badge--problem">Admin</span>
        <h3 class="p-card__title">Gestion Commandes</h3>
        <p class="p-card__body">
          Back-office pour visualiser toutes les commandes et gerer leur statut :
          <strong style="color:var(--p-text)">en_attente → payee → expediee → livree</strong>.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ 04 · PARCOURS & BDD ══════════════════════════════════════ -->
  <section class="p-section" data-reveal>
    <div class="p-section__header">
      <span class="p-section__num">04</span>
      <h2 class="p-section__title">Parcours & Base de Donnees</h2>
      <div class="p-section__line"></div>
    </div>

    <div class="p-grid">
      <div>
        <span class="p-mono" style="color:var(--p-accent);opacity:0.7;display:block;margin-bottom:1.5rem;">UX FLOW</span>
        <ol class="p-steps">
          <li>
            <strong>Page d'accueil</strong>
            <span>Video YouTube en fond + presentation de la marque</span>
          </li>
          <li>
            <strong>Catalogue</strong>
            <span>Navigation et filtrage par categorie (8 categories)</span>
          </li>
          <li>
            <strong>Fiche Produit</strong>
            <span>Images, description, avis, ajout au panier</span>
          </li>
          <li>
            <strong>Inscription / Connexion</strong>
            <span>Authentification JWT securisee</span>
          </li>
          <li>
            <strong>Panier & Checkout</strong>
            <span>Quantites, adresse livraison, paiement Stripe</span>
          </li>
          <li>
            <strong>Confirmation</strong>
            <span>Order Success + suivi dans l'historique</span>
          </li>
        </ol>
      </div>

      <div class="p-card">
        <span class="p-card__label">gymnova_bdd — 8 tables</span>
        <div>
          <div class="p-db-table"><div class="p-db-name">users</div><div class="p-db-fields">id, nom, prenom, email, password, telephone, role</div></div>
          <div class="p-db-table"><div class="p-db-name">categories</div><div class="p-db-fields">id, nom, description, image_url</div></div>
          <div class="p-db-table"><div class="p-db-name">products</div><div class="p-db-fields">id, nom, description, prix, stock, categorie_id</div></div>
          <div class="p-db-table"><div class="p-db-name">product_images</div><div class="p-db-fields">id, product_id, image_url, is_primary</div></div>
          <div class="p-db-table"><div class="p-db-name">cart</div><div class="p-db-fields">id, user_id, product_id, quantite</div></div>
          <div class="p-db-table"><div class="p-db-name">orders</div><div class="p-db-fields">id, user_id, total, statut, adresse_livraison</div></div>
          <div class="p-db-table"><div class="p-db-name">order_items</div><div class="p-db-fields">id, order_id, product_id, quantite, prix_unitaire</div></div>
          <div class="p-db-table"><div class="p-db-name">reviews</div><div class="p-db-fields">id, user_id, product_id, note, commentaire</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ STATS ═════════════════════════════════════════════════════ -->
  <div class="p-stats" data-reveal>
    <div class="p-stat">
      <div class="p-stat__num">8</div>
      <div class="p-stat__label">Tables MySQL</div>
    </div>
    <div class="p-stat">
      <div class="p-stat__num">50</div>
      <div class="p-stat__label">References</div>
    </div>
    <div class="p-stat">
      <div class="p-stat__num">5</div>
      <div class="p-stat__label">Routes API</div>
    </div>
    <div class="p-stat">
      <div class="p-stat__num">11</div>
      <div class="p-stat__label">Pages React</div>
    </div>
  </div>

</ProjectLayout>
