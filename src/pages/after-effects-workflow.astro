---
import ProjectLayout from '../layouts/ProjectLayout.astro'
import heroBgImg from '../assets/bg-after-effects.jpg'
import heroBgImg2 from '../assets/bg-after-effects2.jpg'
---

<ProjectLayout
  title="VFX_LAB | After Effects & Motion Design"
  description="Workflow After Effects, motion design et VFX. Element 3D, Trapcode Suite, Optical Flares, Plexus."
  heroLabel="Creations · Motion Design & VFX"
  heroSub="Mon processus creatif en motion design et effets visuels — de la preproduction a l'export final."
  techTags={["After Effects CC 2024", "Cinema 4D", "Trapcode Suite", "Element 3D", "Plexus", "Saber"]}
  heroBg={heroBgImg.src}
>
  <Fragment slot="hero-title">VFX_<br/>LAB</Fragment>

  <!-- ═══ 01 · LE LOGICIEL ═════════════════════════════════════════ -->
  <section class="p-section" data-reveal>
    <div class="p-section__header">
      <span class="p-section__num">01</span>
      <h2 class="p-section__title">Adobe After Effects</h2>
      <div class="p-section__line"></div>
    </div>

    <div class="p-grid">
      <div class="p-body">
        <p>
          <strong>After Effects</strong> est mon outil principal pour creer du
          motion design, des animations et des effets visuels. Logiciel de
          composition et d'animation qui combine des elements 2D et 3D avec
          des effets visuels complexes.
        </p>
        <p>
          J'utilise AE pour tous mes projets — generiques, transitions, effets
          de texte animes, compositions visuelles complexes. Le systeme de
          calques, les <strong>expressions JavaScript</strong> et la bibliotheque
          d'effets offrent une flexibilite creative egalee.
        </p>

        <div class="p-stack" style="margin-top: 2rem;">
          {["After Effects CC 2024", "Cinema 4D Lite", "Adobe Photoshop", "Adobe Illustrator", "Media Encoder"].map(t => (
            <span class="p-tag">{t}</span>
          ))}
        </div>
      </div>

      <div class="p-card">
        <span class="p-card__label">Outils & Formats</span>
        <div class="p-mono-block">
          <div class="p-mono-block__group">
            <div class="p-mono-block__title">Principal</div>
            <div>After Effects CC 2024</div>
          </div>
          <div class="p-mono-block__group">
            <div class="p-mono-block__title">Assets</div>
            <div>Photoshop + Illustrator</div>
          </div>
          <div class="p-mono-block__group">
            <div class="p-mono-block__title">3D Integre</div>
            <div>Cinema 4D Lite</div>
          </div>
          <div class="p-mono-block__group">
            <div class="p-mono-block__title">Export</div>
            <div>Media Encoder — H.264, ProRes, 4K</div>
          </div>
          <div class="p-mono-block__group">
            <div class="p-mono-block__title">Scripting</div>
            <div>Expressions JavaScript (wiggle, loop, time)</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FEATURED VISUAL ═════════════════════════════════════════ -->
  <div class="p-featured" data-reveal>
    <img src={heroBgImg.src} alt="VFX Lab — Light trails & motion design" loading="lazy" />
    <div class="p-featured__caption">Motion Design · Element 3D · Trapcode Suite · Optical Flares</div>
  </div>

  <!-- ═══ 02 · PLUGINS ════════════════════════════════════════════ -->
  <section class="p-section" data-reveal>
    <div class="p-section__header">
      <span class="p-section__num">02</span>
      <h2 class="p-section__title">Plugins Essentiels</h2>
      <div class="p-section__line"></div>
    </div>

    <p class="p-body" style="max-width:600px; margin-bottom:3.5rem;">
      <span style="opacity:0.6">Ces plugins etendent considerablement les capacites d'After Effects et accelerent le workflow creatif.</span>
    </p>

    <div class="p-features">
      <div class="p-plugin">
        <div class="p-plugin__vendor">Video Copilot</div>
        <span class="p-badge p-badge--arch">Essential</span>
        <h3>Element 3D</h3>
        <p class="p-card__body">Plugin 3D ultra-performant pour importer et animer des modeles directement dans AE. Titres 3D, logos animes, environnements complexes avec rendu rapide.</p>
      </div>

      <div class="p-plugin">
        <div class="p-plugin__vendor">Video Copilot</div>
        <span class="p-badge p-badge--arch">Essential</span>
        <h3>Optical Flares</h3>
        <p class="p-card__body">Lens flares photorealistes et effets de lumiere. Controle total sur la forme, les couleurs et l'intensite pour ajouter du dynamisme aux compositions.</p>
      </div>

      <div class="p-plugin">
        <div class="p-plugin__vendor">Red Giant</div>
        <span class="p-badge p-badge--ux">Creative</span>
        <h3>Trapcode Suite</h3>
        <p class="p-card__body">Suite complete : particules (Particular), formes geometriques (Form), textures procedurales (Mir). Essentiel pour les VFX abstraits et backgrounds animes.</p>
      </div>

      <div class="p-plugin">
        <div class="p-plugin__vendor">Rowbyte</div>
        <span class="p-badge p-badge--ux">Creative</span>
        <h3>Plexus</h3>
        <p class="p-card__body">Reseaux de points et lignes interconnectes en 3D. Visualisations de donnees, backgrounds technologiques, effets de connexion entre elements.</p>
      </div>

      <div class="p-plugin">
        <div class="p-plugin__vendor">Video Copilot — Gratuit</div>
        <span class="p-badge p-badge--arch">Essential</span>
        <h3>Saber</h3>
        <p class="p-card__body">Effets neon, faisceaux laser et lueurs energetiques. Tres utilise pour les transitions sci-fi avec controle precis des courbes de lumiere.</p>
      </div>

      <div class="p-plugin">
        <div class="p-plugin__vendor">RE:Vision Effects</div>
        <span class="p-badge p-badge--ux">Creative</span>
        <h3>Twixtor</h3>
        <p class="p-card__body">Slow-motion fluide meme a partir de footage 24fps, par generation de frames intermediaires haute qualite avec interpolation avancee.</p>
      </div>
    </div>
  </section>

  <!-- ═══ 03 · WORKFLOW ════════════════════════════════════════════ -->
  <section class="p-section" data-reveal>
    <div class="p-section__header">
      <span class="p-section__num">03</span>
      <h2 class="p-section__title">Mon Workflow</h2>
      <div class="p-section__line"></div>
    </div>

    <div class="p-grid">
      <div>
        <ol class="p-steps">
          <li>
            <strong>Concept & Storyboard</strong>
            <span>Definition de l'idee creative, moodboard et esquisse du storyboard pour visualiser les sequences et transitions.</span>
          </li>
          <li>
            <strong>Preparation Assets</strong>
            <span>Creation des elements visuels : graphiques vectoriels (Illustrator), textures (Photoshop), modeles 3D (Cinema 4D), footages video et audio.</span>
          </li>
          <li>
            <strong>Composition & Animation</strong>
            <span>Import dans AE, mise en place de la composition principale, animation des calques avec keyframes, expressions et cameras 3D.</span>
          </li>
          <li>
            <strong>Effets & Post-Production</strong>
            <span>Application des plugins (Element 3D, Trapcode, Plexus), color grading, particules, lens flares et effets de lumiere.</span>
          </li>
          <li>
            <strong>Sound Design & Export</strong>
            <span>Synchronisation audio, optimisation du rendu, export via Media Encoder (H.264, ProRes) selon la destination.</span>
          </li>
        </ol>
      </div>

      <div class="p-card">
        <span class="p-card__label">Techniques Favorites</span>
        <div class="p-body" style="font-size:0.95rem;">
          <p>
            <strong>Expressions JavaScript</strong><br/>
            <span style="opacity:0.7">wiggle(), loop(), time remapping pour des mouvements proceduaux automatises.</span>
          </p>
          <p>
            <strong>Cameras & 3D Layers</strong><br/>
            <span style="opacity:0.7">Profondeur avec cameras virtuelles, calques en espace 3D pour des compositions immersives.</span>
          </p>
          <p>
            <strong>Shape Layers & Motion Graphics</strong><br/>
            <span style="opacity:0.7">Trim paths, gradients et morphing pour des animations vectorielles fluides.</span>
          </p>
          <p>
            <strong>Color Grading</strong><br/>
            <span style="opacity:0.7">Lumetri Color, Curves et Color Balance pour des ambiances cinematiques coherentes.</span>
          </p>
          <p style="margin-bottom:0">
            <strong>Motion Blur & Frame Blending</strong><br/>
            <span style="opacity:0.7">Blur et blending pour des animations naturelles et cinematiques.</span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FEATURED 2 ══════════════════════════════════════════════ -->
  <div class="p-featured" data-reveal>
    <img src={heroBgImg2.src} alt="VFX Lab — Neon light spirals motion design" loading="lazy" />
    <div class="p-featured__caption">Trapcode Suite · Plexus · Optical Flares · Color Grading</div>
  </div>

  <!-- ═══ 04 · GALERIE VIDEO ═══════════════════════════════════════ -->
  <section class="p-section" data-reveal>
    <div class="p-section__header">
      <span class="p-section__num">04</span>
      <h2 class="p-section__title">Galerie Video</h2>
      <div class="p-section__line"></div>
    </div>

    <p class="p-body" style="max-width:600px; margin-bottom:3rem;">
      <span style="opacity:0.6">Quelques creations en motion design et effets visuels.</span>
    </p>

    <div class="p-videos">
      <div class="p-video">
        <iframe
          src="https://www.youtube.com/embed/Q_S17sojDvc?rel=0&modestbranding=1"
          title="Edit VFX 1"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
      <div class="p-video">
        <iframe
          src="https://www.youtube.com/embed/CLxq07EHI-o?rel=0&modestbranding=1"
          title="Edit VFX 2"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
      <div class="p-video">
        <iframe
          src="https://www.youtube.com/embed/-diwAEusMBA?rel=0&modestbranding=1"
          title="Edit VFX 3"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <!-- ═══ STATS ═════════════════════════════════════════════════════ -->
  <div class="p-stats" data-reveal>
    <div class="p-stat">
      <div class="p-stat__num">6</div>
      <div class="p-stat__label">Plugins Pro</div>
    </div>
    <div class="p-stat">
      <div class="p-stat__num">5</div>
      <div class="p-stat__label">Etapes Workflow</div>
    </div>
    <div class="p-stat">
      <div class="p-stat__num">3</div>
      <div class="p-stat__label">Logiciels Adobe</div>
    </div>
    <div class="p-stat">
      <div class="p-stat__num">4K</div>
      <div class="p-stat__label">Export Max</div>
    </div>
  </div>

</ProjectLayout>
