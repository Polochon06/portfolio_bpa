---
import SiteHead from '../components/SiteHead.astro'
import SiteFoot from '../components/SiteFoot.astro'
import SiteScrollbar from '../components/SiteScrollbar.astro'
import '../styles/global.scss'

const base = import.meta.env.BASE_URL
---

<html lang="fr" class="theme-contrasted">
  <head>
    <meta charset="utf-8" />
    <title>The Story | Paul Blanc</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="L'histoire de Paul Blanc — Creative Developer. Trois projets, des milliers de lignes, une vision." />
    <link rel="icon" type="image/png" href={`${base}icons/favicon-48x48.png`} />
    <link rel="preload" href={`${base}fonts/Bigger-Display.woff2`} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={`${base}fonts/PPEditorialNew-Regular.woff2`} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={`${base}fonts/PPFraktionMono-Regular.woff2`} as="font" type="font/woff2" crossorigin="anonymous" />
  </head>

  <body>

    <!-- ░░ PROGRESS BAR ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░ -->
    <div class="st-progress" id="st-progress"></div>

    <div class="site-wrapper js-site-wrapper">
      <SiteHead />

      <main class="st-main">

        <!-- ░░ 00 · HERO ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░ -->
        <section class="st-hero">
          <div class="st-hero__grain"></div>
          <div class="st-hero__lines" aria-hidden="true">
            <div class="st-hero__line-h"></div>
            <div class="st-hero__line-v"></div>
          </div>

          <div class="st-hero__body">
            <span class="st-label st-hero__eyebrow">Paul Blanc · Creative Developer · 2022 — Present</span>
            <h1 class="st-hero__title">
              <span class="st-hero__word js-hero-word">THE</span>
              <span class="st-hero__word js-hero-word">STORY</span>
            </h1>
            <p class="st-hero__sub js-hero-sub">
              Architecture. Commerce. Motion. Three projects.<br/>Thousands of lines. One vision.
            </p>
          </div>

          <div class="st-scroll-cue js-hero-sub">
            <div class="st-scroll-cue__dot"></div>
            <span class="st-label">SCROLL</span>
          </div>
        </section>

        <!-- ░░ 01 · MANIFESTO ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░ -->
        <section class="st-manifesto">
          <div class="st-manifesto__inner">
            <p class="st-manifesto__text js-split-reveal">
              Every line of code<br class="st-br-desktop" />
              is a decision.
            </p>
            <p class="st-manifesto__text js-split-reveal">
              Every project<br class="st-br-desktop" />
              is a commitment.
            </p>
            <p class="st-manifesto__text js-split-reveal" style="color: var(--color-primary);">
              Every creation<br class="st-br-desktop" />
              is a statement.
            </p>
          </div>
        </section>

        <!-- ░░ 02 · CHAPTER 01 — FOUNDATIONS ░░░░░░░░░░░░░░░░░░░░░ -->
        <section class="st-chapter" data-chapter="01">
          <div class="st-chapter__mark">
            <span class="st-chapter__num">01</span>
            <div class="st-chapter__mark-line"></div>
            <span class="st-label st-chapter__label">Foundations</span>
          </div>

          <div class="st-split">
            <div class="st-split__text st-fade-left">
              <span class="st-year">2022</span>
              <h2 class="st-section-title">Building<br/>the Base</h2>
              <p class="st-body">
                Java. SQL. MVC. Before creating experiences, you need to understand structures.
                Before you design, you architect. Before the interface, the system.
              </p>
              <p class="st-body">
                The discipline of backend engineering teaches you that every decision
                has consequences — security, integrity, performance.
              </p>
            </div>
            <div class="st-split__visual st-fade-right">
              <div class="st-code-art">
                <div class="st-code-art__line"><span class="st-code-kw">class</span> <span class="st-code-name">Developer</span> <span class="st-code-br">{</span></div>
                <div class="st-code-art__line st-code-art__line--in"><span class="st-code-kw">String</span> name <span class="st-code-op">=</span> <span class="st-code-str">"Paul"</span>;</div>
                <div class="st-code-art__line st-code-art__line--in"><span class="st-code-kw">boolean</span> creative <span class="st-code-op">=</span> <span class="st-code-bool">true</span>;</div>
                <div class="st-code-art__line st-code-art__line--in"><span class="st-code-kw">int</span> projects <span class="st-code-op">=</span> <span class="st-code-num">3</span>;</div>
                <div class="st-code-art__line st-code-art__line--in"></div>
                <div class="st-code-art__line st-code-art__line--in"><span class="st-code-kw">void</span> <span class="st-code-fn">build</span>() <span class="st-code-br">{</span></div>
                <div class="st-code-art__line st-code-art__line--in2"><span class="st-code-fn">iterate</span>(); <span class="st-code-cm">// always</span></div>
                <div class="st-code-art__line st-code-art__line--in2"><span class="st-code-fn">ship</span>(); <span class="st-code-cm">// eventually</span></div>
                <div class="st-code-art__line st-code-art__line--in"><span class="st-code-br">}</span></div>
                <div class="st-code-art__line"><span class="st-code-br">}</span></div>
              </div>
            </div>
          </div>
        </section>

        <!-- ░░ 03 · PROJECT 01 — MT-CONGÉS ░░░░░░░░░░░░░░░░░░░░░░░ -->
        <section class="st-project st-project--alt">
          <div class="st-project__header">
            <span class="st-label">PROJECT_01 · 2024 · BTS SIO SLAM</span>
          </div>
          <div class="st-project__split">
            <div class="st-project__image st-parallax-img">
              <div class="st-project__image-inner">
                <img
                  src={`${base}images/works/mt-conges-login.png`}
                  alt="MT-Congés — Interface Login"
                  loading="lazy"
                />
              </div>
            </div>
            <div class="st-project__info st-fade-left">
              <h2 class="st-project__title">MT-Congés</h2>
              <p class="st-project__tagline">Architecture Java MVC</p>
              <p class="st-body">
                A complete desktop HR application managing employee leaves
                with multi-level validation workflows, RBAC with 4 permission levels,
                and BCrypt security. Built with Java 17, Swing, MySQL.
              </p>
              <div class="st-project__stack">
                {["Java 17", "Swing", "MySQL", "MVC", "RBAC", "BCrypt"].map(t => (
                  <span class="st-tag">{t}</span>
                ))}
              </div>
              <a href={`${base}mt-conges`} class="st-project__link">
                <span>View project</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>
          </div>
        </section>

        <!-- ░░ 04 · CHAPTER 02 — COMMERCE ░░░░░░░░░░░░░░░░░░░░░░░░ -->
        <section class="st-chapter" data-chapter="02">
          <div class="st-chapter__mark">
            <span class="st-chapter__num">02</span>
            <div class="st-chapter__mark-line"></div>
            <span class="st-label st-chapter__label">E-Commerce</span>
          </div>

          <div class="st-split st-split--reversed">
            <div class="st-split__visual st-fade-left">
              <div class="st-stat-art">
                <div class="st-stat-art__item">
                  <span class="st-stat-art__num">50</span>
                  <span class="st-stat-art__label">Products</span>
                </div>
                <div class="st-stat-art__item">
                  <span class="st-stat-art__num">8</span>
                  <span class="st-stat-art__label">Tables</span>
                </div>
                <div class="st-stat-art__item">
                  <span class="st-stat-art__num">11</span>
                  <span class="st-stat-art__label">Pages React</span>
                </div>
                <div class="st-stat-art__item">
                  <span class="st-stat-art__num">5</span>
                  <span class="st-stat-art__label">API Routes</span>
                </div>
              </div>
            </div>
            <div class="st-split__text st-fade-right">
              <span class="st-year">2024</span>
              <h2 class="st-section-title">Building<br/>Commerce</h2>
              <p class="st-body">
                React on the front, Node.js at the back. A full e-commerce
                system with Stripe payments, JWT authentication,
                and an admin dashboard. End-to-end product development.
              </p>
              <p class="st-body">
                From catalog to checkout. From browse to buy. From API
                to interface — a full-stack journey.
              </p>
            </div>
          </div>
        </section>

        <!-- ░░ 05 · PROJECT 02 — GYMNOVA ░░░░░░░░░░░░░░░░░░░░░░░░░ -->
        <section class="st-project">
          <div class="st-project__header">
            <span class="st-label">PROJECT_02 · 2024 · BTS SIO SLAM</span>
          </div>
          <div class="st-project__split">
            <div class="st-project__image st-parallax-img">
              <div class="st-project__image-inner">
                <img
                  src={`${base}images/works/mt-conges-dashboard.png`}
                  alt="Gymnova Shop"
                  loading="lazy"
                />
              </div>
            </div>
            <div class="st-project__info st-fade-right">
              <h2 class="st-project__title">Gymnova Shop</h2>
              <p class="st-project__tagline">E-Commerce React</p>
              <p class="st-body">
                A professional gymnastics equipment e-commerce with 50 products
                across 8 categories, Stripe checkout, JWT auth, and a full admin
                panel. Built with React 18, Express, and MySQL.
              </p>
              <div class="st-project__stack">
                {["React 18", "Node.js", "Express", "MySQL", "Stripe", "JWT"].map(t => (
                  <span class="st-tag">{t}</span>
                ))}
              </div>
              <a href={`${base}gymnova`} class="st-project__link">
                <span>View project</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>
          </div>
        </section>

        <!-- ░░ 06 · CHAPTER 03 — MOTION ░░░░░░░░░░░░░░░░░░░░░░░░░░ -->
        <section class="st-chapter" data-chapter="03">
          <div class="st-chapter__mark">
            <span class="st-chapter__num">03</span>
            <div class="st-chapter__mark-line"></div>
            <span class="st-label st-chapter__label">Motion</span>
          </div>

          <div class="st-split">
            <div class="st-split__text st-fade-left">
              <span class="st-year">2023–24</span>
              <h2 class="st-section-title">Beyond<br/>the Screen</h2>
              <p class="st-body">
                Code ends where the screen begins — but creativity
                doesn't stop there. After Effects, Element 3D,
                Trapcode Suite. The same logical mind, applied to
                motion and visual storytelling.
              </p>
              <p class="st-body">
                Motion design is just programming with time as the variable.
              </p>
            </div>
            <div class="st-split__visual st-fade-right">
              <div class="st-motion-art">
                <div class="st-motion-art__ring st-motion-art__ring--1"></div>
                <div class="st-motion-art__ring st-motion-art__ring--2"></div>
                <div class="st-motion-art__ring st-motion-art__ring--3"></div>
                <div class="st-motion-art__core">
                  <span>VFX</span>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- ░░ 07 · PROJECT 03 — VFX_LAB ░░░░░░░░░░░░░░░░░░░░░░░░░ -->
        <section class="st-project st-project--dark">
          <div class="st-project__header">
            <span class="st-label">PROJECT_03 · Motion Design & VFX</span>
          </div>
          <div class="st-project__video-wrap st-fade-left">
            <div class="st-video-frame">
              <iframe
                src="https://www.youtube.com/embed/-diwAEusMBA?rel=0&modestbranding=1&controls=0&mute=1&autoplay=0"
                title="VFX_LAB — Motion Design"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
            </div>
            <div class="st-project__info st-project__info--video">
              <h2 class="st-project__title">VFX_LAB</h2>
              <p class="st-project__tagline">After Effects & Motion Design</p>
              <p class="st-body">
                Element 3D. Optical Flares. Trapcode Suite. Plexus.
                Six professional plugins. One creative process.
              </p>
              <div class="st-project__stack">
                {["After Effects", "Element 3D", "Trapcode", "Plexus", "Saber", "Twixtor"].map(t => (
                  <span class="st-tag">{t}</span>
                ))}
              </div>
              <a href={`${base}after-effects-workflow`} class="st-project__link">
                <span>View project</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>
          </div>
        </section>

        <!-- ░░ 08 · SKILLS MARQUEE ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░ -->
        <section class="st-marquee-section">
          <div class="st-marquee" aria-hidden="true">
            <div class="st-marquee__track js-marquee">
              {[
                "Java", "React", "Node.js", "MySQL", "GSAP", "After Effects",
                "MVC", "REST API", "Stripe", "JWT", "Swing", "Element 3D",
                "Java", "React", "Node.js", "MySQL", "GSAP", "After Effects",
                "MVC", "REST API", "Stripe", "JWT", "Swing", "Element 3D",
              ].map((skill, i) => (
                <span class="st-marquee__item">
                  {skill}
                  <span class="st-marquee__dot">·</span>
                </span>
              ))}
            </div>
          </div>
        </section>

        <!-- ░░ 09 · CLOSING ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░ -->
        <section class="st-closing">
          <div class="st-closing__grain"></div>
          <div class="st-closing__content">
            <span class="st-label st-closing__label">The conclusion</span>
            <h2 class="st-closing__title js-closing-title">
              <span class="js-closing-word">Creative</span>
              <span class="js-closing-word" style="color: var(--color-primary);">Developer</span>
            </h2>
            <p class="st-closing__sub">
              Architecture, commerce, motion — three domains, one mindset.<br/>
              Building experiences that matter.
            </p>
            <a href={`${base}`} class="st-closing__cta">
              <span>See the work</span>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
          <div class="st-closing__counter">
            <div class="st-closing__stat"><span class="st-label">Projects</span><strong>3</strong></div>
            <div class="st-closing__stat"><span class="st-label">Tables SQL</span><strong>15+</strong></div>
            <div class="st-closing__stat"><span class="st-label">Plugins AE</span><strong>6</strong></div>
            <div class="st-closing__stat"><span class="st-label">Stack layers</span><strong>∞</strong></div>
          </div>
        </section>

      </main>

      <SiteFoot />
    </div>

    <SiteScrollbar />
  </body>

  <!-- ░░ SCRIPT ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░ -->
  <script>
    import Emitter from '../utils/Emitter'
    import Ticker from '../utils/Ticker'
    import Lenis from 'lenis'
    import { gsap } from 'gsap'
    import { ScrollTrigger } from 'gsap/ScrollTrigger'
    import { SplitText } from 'gsap/SplitText'
    gsap.registerPlugin(ScrollTrigger, SplitText)

    declare global {
      interface Window {
        safeWidth: number; safeHeight: number
        maxScrollTop: number; scrollProgress: number; lenis: any
      }
    }

    /* ── Site bootstrap ─────────────────────────────────────────── */
    class Site {
      timeouts: any = { resizeThrottle: null }
      windowWidth: number = 0; windowHeight: number = 0
      clientWidth: number = 0; clientHeight: number = 0
      lenis: any

      constructor() {
        const ua = navigator.userAgent
        const os = ua.includes('Win') ? 'windows' : ua.includes('Android') ? 'android' : ua.includes('Mac') ? 'mac' : 'linux'
        const br = ua.includes('Firefox') ? 'firefox' : ua.includes('Chrome') ? 'chrome' : 'safari'
        document.documentElement.classList.add(`is-${os}`, `is-${br}`)
        this.bindEvents()
      }

      init() {
        this.initLenis()
        Ticker.init()
        this.onResize()
        document.dispatchEvent(new CustomEvent('intro'))
        Ticker.nextTick(() => Emitter.emit('updateViewport'))
        this.initStory()
      }

      bindEvents() {
        window.addEventListener('resize', this.resizeThrottle.bind(this))
        window.addEventListener('scroll', this.onScroll.bind(this), { passive: true })
        window.addEventListener('mousemove', (e: MouseEvent) => Emitter.emit('mousemove', e.clientX, e.clientY), { passive: true })
        Emitter.on('updateViewport', this.onResize, this, true)
        if (document.readyState === 'complete') this.siteLoaded()
        else window.addEventListener('load', this.siteLoaded.bind(this), { once: true })
        this.onScroll()
      }

      initLenis() {
        const lenis = new Lenis()
        lenis.on('scroll', ScrollTrigger.update)
        gsap.ticker.add((time) => lenis.raf(time * 1000))
        gsap.ticker.lagSmoothing(0)
        window.lenis = lenis; this.lenis = lenis
      }

      siteLoaded() {
        document.documentElement.classList.add('is-loaded')
        Emitter.emit('siteLoaded')
      }

      resizeThrottle() {
        clearTimeout(this.timeouts.resizeThrottle)
        this.timeouts.resizeThrottle = setTimeout(() => Ticker.nextTick(this.onResize, this), 200)
      }

      onResize() {
        this.windowWidth = window.innerWidth; this.clientWidth = document.body.clientWidth
        this.windowHeight = window.innerHeight; this.clientHeight = document.body.clientHeight
        window.safeWidth = this.windowWidth; window.safeHeight = this.windowHeight
        window.maxScrollTop = document.body.scrollHeight - window.safeHeight
        this.setScrollProgress()
        Emitter.emit('resize', true)
      }

      onScroll() {
        this.setScrollProgress()
        Ticker.nextTick(() => Emitter.emit('scroll', window.scrollY))
      }

      setScrollProgress() {
        window.scrollProgress = window.scrollY / window.maxScrollTop
      }

      /* ── Story animations ──────────────────────────────────────── */
      initStory() {
        this.initProgress()
        this.initHero()
        this.initManifesto()
        this.initFadeElements()
        this.initParallax()
        this.initMarquee()
        this.initClosing()
      }

      /* Progress bar */
      initProgress() {
        const bar = document.getElementById('st-progress')
        if (!bar) return
        gsap.to(bar, {
          scaleX: 1,
          ease: 'none',
          scrollTrigger: { trigger: 'body', start: 'top top', end: 'bottom bottom', scrub: 0 },
        })
      }

      /* Hero entrance */
      initHero() {
        const words = document.querySelectorAll('.js-hero-word')
        const subs  = document.querySelectorAll('.js-hero-sub')

        const tl = gsap.timeline({ delay: 0.3 })
        tl.fromTo(words,
          { y: '110%', opacity: 0 },
          { y: '0%', opacity: 1, duration: 1.2, ease: 'expo.out', stagger: 0.12 }
        )
        tl.fromTo(subs,
          { y: 20, opacity: 0 },
          { y: 0, opacity: 1, duration: 1, ease: 'expo.out', stagger: 0.1 },
          '-=0.6'
        )
      }

      /* Manifesto — each paragraph reveals on scroll */
      initManifesto() {
        const texts = document.querySelectorAll('.js-split-reveal')
        texts.forEach((el) => {
          const split = new SplitText(el, { type: 'lines', linesClass: 'st-split-line' })
          gsap.fromTo(split.lines,
            { y: '100%', opacity: 0 },
            {
              y: '0%', opacity: 1, duration: 1, ease: 'expo.out', stagger: 0.08,
              scrollTrigger: { trigger: el, start: 'top 80%', toggleActions: 'play none none reverse' },
            }
          )
        })
      }

      /* Generic fade elements */
      initFadeElements() {
        const fadeLeft  = document.querySelectorAll('.st-fade-left')
        const fadeRight = document.querySelectorAll('.st-fade-right')
        const fadeUp    = document.querySelectorAll('.st-fade-up')

        const makeAnim = (el: Element, x: number, y: number) => {
          gsap.fromTo(el,
            { x, y, opacity: 0 },
            {
              x: 0, y: 0, opacity: 1, duration: 1.1, ease: 'expo.out',
              scrollTrigger: { trigger: el, start: 'top 85%', toggleActions: 'play none none reverse' },
            }
          )
        }

        fadeLeft.forEach(el => makeAnim(el, -50, 0))
        fadeRight.forEach(el => makeAnim(el, 50, 0))
        fadeUp.forEach(el => makeAnim(el, 0, 40))

        // Chapter mark + number
        document.querySelectorAll('.st-chapter__num').forEach((el) => {
          gsap.fromTo(el,
            { opacity: 0, y: 20 },
            {
              opacity: 1, y: 0, duration: 1, ease: 'expo.out',
              scrollTrigger: { trigger: el, start: 'top 80%' },
            }
          )
        })
      }

      /* Parallax on project images */
      initParallax() {
        document.querySelectorAll('.st-parallax-img').forEach((wrap) => {
          const img = wrap.querySelector('.st-project__image-inner')
          if (!img) return
          gsap.fromTo(img,
            { y: '-8%' },
            {
              y: '8%', ease: 'none',
              scrollTrigger: { trigger: wrap, start: 'top bottom', end: 'bottom top', scrub: 1 },
            }
          )
        })
      }

      /* Marquee */
      initMarquee() {
        const track = document.querySelector('.js-marquee') as HTMLElement
        if (!track) return
        const totalW = track.scrollWidth / 2
        gsap.to(track, {
          x: -totalW,
          duration: 30,
          ease: 'none',
          repeat: -1,
        })
      }

      /* Closing title */
      initClosing() {
        const words = document.querySelectorAll('.js-closing-word')
        gsap.fromTo(words,
          { y: 60, opacity: 0 },
          {
            y: 0, opacity: 1, duration: 1.2, ease: 'expo.out', stagger: 0.15,
            scrollTrigger: { trigger: '.st-closing', start: 'top 70%' },
          }
        )
      }
    }

    const site = new Site()
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => site.init(), { once: true })
    } else {
      site.init()
    }
  </script>
</html>

