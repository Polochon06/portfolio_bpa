---
---

<div class="site-cursor js-cursor" aria-hidden="true">
  <div class="cursor__dot js-cursor-dot"></div>
  <div class="cursor__ring js-cursor-ring"></div>
</div>

<script>
  const isTouchDevice = window.matchMedia('(hover: none), (pointer: coarse)').matches
  if (isTouchDevice) {
    // skip on touch — leave default cursor
  } else {
    document.documentElement.classList.add('has-custom-cursor')

    const dot  = document.querySelector('.js-cursor-dot')  as HTMLElement
    const ring = document.querySelector('.js-cursor-ring') as HTMLElement

    if (!dot || !ring) throw new Error('SiteCursor: elements not found')

    let mx = window.innerWidth  / 2
    let my = window.innerHeight / 2
    let rx = mx, ry = my
    let hovering = false
    let magnetTarget: HTMLElement | null = null
    let raf: number

    const LERP  = 0.12
    const LERP_M = 0.08 // slower lerp for magnetic

    function lerp(a: number, b: number, t: number) { return a + (b - a) * t }

    function tick() {
      if (magnetTarget) {
        const r = magnetTarget.getBoundingClientRect()
        const cx = r.left + r.width  / 2
        const cy = r.top  + r.height / 2
        const ox = (mx - cx) * 0.35
        const oy = (my - cy) * 0.35
        magnetTarget.style.transform = `translate(${ox}px, ${oy}px)`
        rx = lerp(rx, cx + ox, LERP_M)
        ry = lerp(ry, cy + oy, LERP_M)
      } else {
        rx = lerp(rx, mx, LERP)
        ry = lerp(ry, my, LERP)
      }

      dot.style.transform  = `translate(${mx}px, ${my}px) translate(-50%, -50%)`
      ring.style.transform = `translate(${rx}px, ${ry}px) translate(-50%, -50%)`

      raf = requestAnimationFrame(tick)
    }
    raf = requestAnimationFrame(tick)

    // Track mouse
    window.addEventListener('mousemove', (e: MouseEvent) => {
      mx = e.clientX
      my = e.clientY
    }, { passive: true })

    // Hover interactive elements
    const INTERACTIVE = 'a, button, [role="button"], input, textarea, select, label, [data-cursor-hover], .p-card, .p-cat-item, .p-cta__link'

    document.addEventListener('mouseover', (e: MouseEvent) => {
      if ((e.target as HTMLElement).closest(INTERACTIVE)) {
        hovering = true
        ring.classList.add('is-hover')
        dot.classList.add('is-hover')
      }
    })
    document.addEventListener('mouseout', (e: MouseEvent) => {
      if ((e.target as HTMLElement).closest(INTERACTIVE)) {
        hovering = false
        ring.classList.remove('is-hover')
        dot.classList.remove('is-hover')
      }
    })

    // Magnetic effect
    document.addEventListener('mouseover', (e: MouseEvent) => {
      const el = (e.target as HTMLElement).closest('[data-magnetic]') as HTMLElement | null
      if (el) {
        magnetTarget = el
        ring.classList.add('is-magnetic')
      }
    })
    document.addEventListener('mouseout', (e: MouseEvent) => {
      const el = (e.target as HTMLElement).closest('[data-magnetic]') as HTMLElement | null
      if (el && magnetTarget) {
        magnetTarget.style.transform = ''
        magnetTarget = null
        ring.classList.remove('is-magnetic')
      }
    })

    // Mousedown / mouseup press state
    document.addEventListener('mousedown', () => { ring.classList.add('is-press'); dot.classList.add('is-press') })
    document.addEventListener('mouseup',   () => { ring.classList.remove('is-press'); dot.classList.remove('is-press') })
  }
</script>

<style is:global>
  .has-custom-cursor,
  .has-custom-cursor * { cursor: none !important; }

  .site-cursor { pointer-events: none; }

  .cursor__dot,
  .cursor__ring {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 99999;
    will-change: transform;
  }

  .cursor__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #a78bfa;
    box-shadow: 0 0 8px rgba(167,139,250,0.8);
    transition: width 0.2s, height 0.2s, background 0.2s;
  }
  .cursor__dot.is-hover {
    width: 10px;
    height: 10px;
    background: #c4b5fd;
  }
  .cursor__dot.is-press {
    width: 4px;
    height: 4px;
  }

  .cursor__ring {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1px solid rgba(167,139,250,0.55);
    background: transparent;
    transition: width 0.3s cubic-bezier(0.22,1,0.36,1),
                height 0.3s cubic-bezier(0.22,1,0.36,1),
                border-color 0.3s,
                background 0.3s,
                opacity 0.3s;
  }
  .cursor__ring.is-hover {
    width: 52px;
    height: 52px;
    border-color: rgba(167,139,250,0.75);
    background: rgba(139,92,246,0.07);
  }
  .cursor__ring.is-magnetic {
    width: 60px;
    height: 60px;
    border-color: rgba(167,139,250,0.9);
    background: rgba(139,92,246,0.12);
  }
  .cursor__ring.is-press {
    width: 28px;
    height: 28px;
    background: rgba(139,92,246,0.18);
  }
</style>
