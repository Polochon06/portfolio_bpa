---
const { caption, description, cssClass, index, site, src, total, type } = Astro.props

// Parse tech tags from description
const techMatch = description?.match(/TECH:\s*([^\n.]+)/i)
const techTags = techMatch
  ? techMatch[1].split(',').map((t: string) => t.trim()).filter(Boolean).slice(0, 6)
  : []

const key = Math.random().toString(36).slice(2, 6) + '-' + index + '/' + total
const displayIndex = String(parseInt(index) + 1).padStart(2, '0')
---

<a-work class={cssClass}>
  <div class="a__inner">
    <a href={site} target="_blank">

      <div class="a__media">
        {type === 'youtube' ? (
          <iframe
            data-src={src}
            class="a__video js-video"
            width="1082"
            height="636"
            frameborder="0"
            allow="autoplay; encrypted-media"
            style="pointer-events: none;"
          ></iframe>
        ) : type === 'image' ? (
          <img
            src={src}
            class="a__video js-video"
            width="1082"
            height="636"
            alt={caption}
            loading="lazy"
          />
        ) : (
          <video
            data-src={src}
            class="a__video js-video"
            loop
            muted
            playsinline
            width="1082"
            height="636"
          >
          </video>
        )}

        <div class="a__index">_{displayIndex}</div>
        <div class="a__overlay"></div>
      </div>

      <div class="a__footer">
        <div class="a__footer__row">
          <div class="a__caption">{caption}</div>
          <div class="a__arrow">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </div>
        </div>

        {techTags.length > 0 && (
          <div class="a__tags">
            {techTags.map((tag: string) => (
              <span class="a__tag">{tag}</span>
            ))}
          </div>
        )}

        <div class="a__key">#{key}</div>
      </div>

    </a>
  </div>
</a-work>

<script>
  class AWork extends HTMLElement {
    static observedAttributes = ['progress']

    link: HTMLAnchorElement
    video: HTMLVideoElement | HTMLIFrameElement

    isPlaying: boolean

    /**
     * Init
     */
    connectedCallback() {
      // Elements
      this.video = this.querySelector('.js-video')
      this.link = this.querySelector('a')

      // Properties
      this.isPlaying = false

      // Events
      this.link.addEventListener('click', this.onClick.bind(this))
    }

    /**
     * Attribute changed
     */
    attributeChangedCallback(name, oldValue, newValue) {
      if (name === 'progress') {
        this.style.setProperty('--progress', newValue)

        if (newValue === '1' || newValue === '-1') {
          if (this.isPlaying) {
            this.outView()
          }
        } else {
          if (!this.isPlaying) {
            this.inView()
          }
        }
      }
    }

    /**
     * Gets in view
     */
    inView() {
      if (this.video) {
        if (this.video.tagName === 'VIDEO') {
          (this.video as HTMLVideoElement).play()
        } else if (this.video.tagName === 'IFRAME') {
           const iframe = this.video as HTMLIFrameElement
           if (!iframe.src) {
             iframe.src = iframe.dataset.src || ''
           }
        }
      }
      this.isPlaying = true

      this.classList.add('is-inview')
    }

    /**
     * Gets out view
     */
    outView() {
      if (this.video) {
        if (this.video.tagName === 'VIDEO') {
          (this.video as HTMLVideoElement).pause()
        }
        // Do not clear src for iframes to prevent reloading/flashing
      }
      this.isPlaying = false

      this.classList.remove('is-inview')
    }

    /**
     * On click
     */
    onClick(event: MouseEvent) {
      if (this.link.href.includes('#') && !this.link.href.includes('youtube')) {
        event.preventDefault()
        return false
      }
    }
  }

  customElements.define('a-work', AWork)
</script>

<style lang="scss">
  a-work {
    position: relative;
    top: 0;
    left: 0;

    display: block;
    margin: 0;
    padding: 0;

    background: color(secondary);
    border: 1px solid rgba(139, 92, 246, 0.25);
    content-visibility: hidden;

    transform-style: preserve-3d;
    will-change: transform;

    transition: border-color 0.3s ease;

    &:hover {
      border-color: rgba(139, 92, 246, 0.7);
    }

    a {
      display: block;
      text-decoration: none;
    }

    .a__inner {
      position: relative;
      display: block;
      margin: 0;
      padding: 0;
    }

    // ─── Media block ───────────────────────────────────────────

    .a__media {
      position: relative;
      overflow: hidden;
    }

    .a__video {
      display: block;
      width: 100%;
      max-width: 50vw;
      height: auto;
      aspect-ratio: 16 / 9;
      object-fit: cover;

      transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);

      @include mq(phone) {
        max-width: 80vw;
      }
    }

    iframe.a__video {
      max-width: 60vw;
      @include mq(phone) {
        max-width: 90vw;
      }
    }

    img.a__video {
      max-width: 40vw;
      @include mq(phone) {
        max-width: 70vw;
      }
    }

    a:hover .a__video {
      transform: scale(1.04);
    }

    // Dark gradient overlay on media
    .a__overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        transparent 40%,
        rgba(0, 0, 0, 0.55) 100%
      );
      pointer-events: none;
    }

    // Large index number over image
    .a__index {
      position: absolute;
      top: 0.6rem;
      left: 0.75rem;

      font: 700 3.5rem / 1 font-family(bigger);
      color: color(white);
      opacity: 0.18;
      letter-spacing: -0.03em;
      text-transform: uppercase;
      pointer-events: none;
      user-select: none;

      transition: opacity 0.3s ease;

      @include mq(phone) {
        font-size: 2.5rem;
      }
    }

    a:hover .a__index {
      opacity: 0.38;
    }

    // ─── Footer block ──────────────────────────────────────────

    .a__footer {
      padding: 0.75rem 0.875rem 0.875rem;
      background: color(secondary);
      border-top: 1px solid rgba(139, 92, 246, 0.2);
    }

    .a__footer__row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
      margin-bottom: 0.5rem;
    }

    .a__caption {
      font: 700 0.75rem / 1.2 font-family(fraktion);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: color(white);
    }

    .a__arrow {
      flex-shrink: 0;
      color: color(primary);
      opacity: 0.6;

      transition: opacity 0.25s ease, transform 0.25s ease;

      svg {
        display: block;
      }
    }

    a:hover .a__arrow {
      opacity: 1;
      transform: translateX(3px);
    }

    // Tech tags
    .a__tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.3rem;
      margin-bottom: 0.5rem;
    }

    .a__tag {
      display: inline-block;
      padding: 0.2rem 0.5rem;
      border: 1px solid rgba(139, 92, 246, 0.45);
      border-radius: 2px;

      font: 600 9px / 1.4 font-family(fraktion);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: color(primary);

      transition: background 0.2s ease, border-color 0.2s ease;
    }

    a:hover .a__tag {
      background: rgba(139, 92, 246, 0.12);
      border-color: rgba(139, 92, 246, 0.7);
    }

    // Hash key
    .a__key {
      font: 400 9px / 1 font-family(fraktion);
      letter-spacing: 0.1em;
      color: color(white);
      opacity: 0.25;
      text-transform: uppercase;
    }

    &.is-inview {
      content-visibility: visible;
    }
  }
</style>
